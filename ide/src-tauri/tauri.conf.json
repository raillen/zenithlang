{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenith Keter",
  "version": "0.1.0",
  "identifier": "com.zenith.prism",
  "build": {
    "beforeDevCommand": "npm run tauri:dev:server",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": [
        "main"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "Zenith Keter",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
