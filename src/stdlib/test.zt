namespace std.test

import std.core

extern func "zt.test.describe" zt_test_describe(name: text, body: any)
extern func "zt.test.test" zt_test_test(name: text, body: any)
extern func "zt.test.before_each" zt_test_before_each(body: any)
extern func "zt.test.after_each" zt_test_after_each(body: any)
extern func "zt.test.assert_eq" zt_test_assert_eq(actual: any, expected: any)
extern func "zt.test.assert_true" zt_test_assert_true(condition: bool)
extern func "zt.test.assert_false" zt_test_assert_false(condition: bool)
extern func "zt.test.assert_snapshot" zt_test_assert_snapshot(name: text, content: any)
extern func "zt.test.assert_outcome_success" zt_test_assert_outcome_success(res: Outcome<any>)
extern func "zt.test.assert_outcome_failure" zt_test_assert_outcome_failure(res: Outcome<any>)
extern func "zt.test.run_all" zt_test_run_all() -> bool

pub func describe(name: text, body: any)
    zt_test_describe(name, body)
end

pub func test(name: text, body: any)
    zt_test_test(name, body)
end

pub func before_each(body: any)
    zt_test_before_each(body)
end

pub func after_each(body: any)
    zt_test_after_each(body)
end

pub func assert_eq(actual: any, expected: any)
    zt_test_assert_eq(actual, expected)
end

pub func assert_true(condition: bool)
    zt_test_assert_true(condition)
end

pub func assert_false(condition: bool)
    zt_test_assert_false(condition)
end

pub func assert_snapshot(name: text, content: any)
    zt_test_assert_snapshot(name, content)
end

pub func assert_outcome_success(res: Outcome<any>)
    zt_test_assert_outcome_success(res)
end

pub func assert_outcome_failure(res: Outcome<any>)
    zt_test_assert_outcome_failure(res)
end

--- Executa todos os testes registrados no processo atual.
pub func run_all() -> bool
    return zt_test_run_all()
end
