

extern func "io.write" lua_write(v: text)
extern func "print"    lua_print(v: text)
extern func "io.read"  lua_read(fmt: text) -> any

pub func write(value: any)
    lua_write(tostring(value))
end

pub func write_line(value: any)
    lua_print(tostring(value))
end

pub func read_line() -> Optional<text>
    var line = lua_read("*l")
    if line != nil
        return Present(line)
    end
    return Empty
end
