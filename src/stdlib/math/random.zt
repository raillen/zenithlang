--- Biblioteca Padrão Zenith — Submódulo Random
--- Motor de sorte e probabilidade.

namespace std.math.random

--- Inicializa a semente do gerador aleatório.
pub func seed(val: int)
end

--- Retorna um número flutuante entre min e max.
pub func float(min: float = 0.0, max: float = 1.0) -> float
end

--- Retorna um número inteiro entre min e max (inclusivo).
pub func int(min: int, max: int) -> int
end

--- Retorna um booleano aleatório (50/50).
pub func bool() -> bool
end
