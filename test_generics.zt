import std.io

-- 1. Função de Identidade Genérica
func id<T>(x: T) -> T
    return x
end

-- 2. Struct Genérica
struct Box<T>
    value: T
end

func main()
    -- 3. Teste de Chamada Explícita
    var n1: int = id<int>(10)
    io.println("n1 (explícito): " .. n1.to_text())
    
    -- 4. Teste de Inferência Automática
    var n2: int = id(20)
    io.println("n2 (inferido): " .. n2.to_text())
    
    var s1: text = id("olá generics")
    io.println("s1: " .. s1)
    
    -- 5. Teste de Struct Genérica
    var b1 = Box<int> { value: 100 }
    io.println("b1.value: " .. b1.value.to_text())
    
    var b2 = Box<text> { value: "texto na box" }
    io.println("b2.value: " .. b2.value)

    -- 6. Testes de Erro (Descomente para testar falha de compilação)
    -- var err1: text = id(42) -- Erro esperado: int não é text
    -- var err2 = Box<int> { value: "erro" } -- Erro esperado: text não é int
    
    io.println("Todos os testes de generics (sucesso) passaram!")
end
