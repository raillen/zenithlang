{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Borealis Studio",
  "version": "0.1.0",
  "identifier": "dev.zenith.borealis-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Borealis Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
