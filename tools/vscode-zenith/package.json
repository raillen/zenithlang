{
  "name": "zenith-vscode",
  "displayName": "Zenith Language",
  "description": "Language support for Zenith files with Compass LSP.",
  "version": "1.0.0",
  "publisher": "zenith-lang",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0F1114",
    "theme": "dark"
  },
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raillen/zenithlang.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:zenith",
    "onCommand:zenith.newFile",
    "onCommand:zenith.check",
    "onCommand:zenith.build",
    "onCommand:zenith.run",
    "workspaceContains:**/*.zt",
    "workspaceContains:**/zenith.ztproj"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "python ../../tools/package_vscode_extension.py"
  },
  "contributes": {
    "languages": [
      {
        "id": "zenith",
        "aliases": ["Zenith", "zenith"],
        "extensions": [".zt"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zenith",
        "scopeName": "source.zenith",
        "path": "./syntaxes/zenith.tmLanguage.json"
      }
    ],
    "commands": [
      { "command": "zenith.newFile", "title": "New File", "category": "Zenith" },
      { "command": "zenith.check", "title": "Check Project", "category": "Zenith" },
      { "command": "zenith.build", "title": "Build Project", "category": "Zenith" },
      { "command": "zenith.run", "title": "Run Project", "category": "Zenith" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "zenith.newFile" },
        { "command": "zenith.check" },
        { "command": "zenith.build" },
        { "command": "zenith.run" }
      ]
    },
    "configuration": {
      "title": "Zenith",
      "properties": {
        "zenith.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to zt-lsp. Empty means use the repository binary or PATH."
        },
        "zenith.cli.path": {
          "type": "string",
          "default": "",
          "description": "Path to zt CLI. Empty means use the repository binary or PATH."
        },
        "zenith.files.autoNamespaceOnCreate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically insert a namespace in empty .zt files created under source.root."
        }
      }
    }
  }
}
