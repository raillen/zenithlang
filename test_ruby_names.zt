func is_even?(n: int) -> bool {
    return n % 2 == 0
}

func bang!(n: int) {
    print("Bang! " + n)
}

struct User {
    var name: text
    var active?: bool

    func activate!() {
        @active? = true
    }
}

func main() {
    var x? = is_even?(10)
    print("x? is " + x?)

    bang!(42)

    var u = User(name: "Alice", active?: false)
    print("User active? " + u.active?)
    u.activate!()
    print("User active? " + u.active?)
}
