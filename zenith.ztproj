-- Projeto de Exemplo Zenith
project meu_projeto
    version: 0.2.5
    author:  "Rafael"
end

build
    main: tests/core/test_v02_refinement.zt
    out:  dist/bundle.lua
    
    @optimize(true)
    @target(lua_5_1)
end

dependencies
    std: official
end

scripts
    test:    "zt tests/core/test_v02_refinement.zt"
    test-os: "zt tests/stdlib/test_os.zt --run"
end
