-- Biblioteca Padrão Zenith — Módulo Validate
-- Predicados de validação para inteiros e texto.
-- 🔢 VALIDAÇÃO DE INTEIROS
-- 📝 VALIDAÇÃO DE TEXTO
namespace std.validate

public func between(value: int, min: int, max: int) -> bool
    return value >= min and value <= max
end

public func positive(value: int) -> bool
    return value > 0
end

public func non_negative(value: int) -> bool
    return value >= 0
end

public func negative(value: int) -> bool
    return value < 0
end

public func non_zero(value: int) -> bool
    return value != 0
end

public func one_of(value: int, candidates: list<int>) -> bool
    for item in candidates
        if item == value
            return true
        end
    end
    return false
end

public func not_empty(value: text) -> bool
    return len(value) > 0
end

public func min_length(value: text, min: int) -> bool
    return len(value) >= min
end

public func max_length(value: text, max: int) -> bool
    return len(value) <= max
end

public func length_between(value: text, min: int, max: int) -> bool
    const count: int = len(value)
    return count >= min and count <= max
end

public func no_whitespace(value: text) -> bool
    const space: text = " "
    const tab: text = "\t"
    const newline: text = "\n"
    const carriage: text = "\r"

    for ch in value
        if ch == space or ch == tab or ch == newline or ch == carriage
            return false
        end
    end

    return true
end

public func has_whitespace(value: text) -> bool
    const space: text = " "
    const tab: text = "\t"
    const newline: text = "\n"
    const carriage: text = "\r"

    for ch in value
        if ch == space or ch == tab or ch == newline or ch == carriage
            return true
        end
    end

    return false
end

