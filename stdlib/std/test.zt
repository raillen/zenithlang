-- Biblioteca Padrao Zenith - modulo Test.
-- Sinalizacao de falha e skip para o runner de testes.
namespace std.test

extern c
    func zt_text_concat(a: text, b: text) -> text
end

func _join3(a: text, b: text, c: text) -> text
    const left: text = test.zt_text_concat(a, b)
    return test.zt_text_concat(left, c)
end

func _join4(a: text, b: text, c: text, d: text) -> text
    const left: text = test._join3(a, b, c)
    return test.zt_text_concat(left, d)
end

public func zt_test_fail(message: text) -> void
    const _message: text = message
    return
end

public func zt_test_skip(reason: text) -> void
    const _reason: text = reason
    return
end

public func fail(message: text = "test failed") -> void
    test.zt_test_fail(message)
end

public func skip(reason: text = "") -> void
    test.zt_test_skip(reason)
end

public func is_true(value: bool) -> void
    if value == false
        test.fail("expected true; received false")
    end

    return
end

public func is_false(value: bool) -> void
    if value == true
        test.fail("expected false; received true")
    end

    return
end

public func equal_int(actual: int, expected: int) -> void
    if actual != expected
        const expected_text: text = to_text(expected)
        const actual_text: text = to_text(actual)
        const message: text = test._join4("expected ", expected_text, "; received ", actual_text)
        test.fail(message)
    end

    return
end

public func equal_text(actual: text, expected: text) -> void
    if actual != expected
        const message: text = test._join4("expected ", expected, "; received ", actual)
        test.fail(message)
    end

    return
end

public func not_equal_int(actual: int, expected: int) -> void
    if actual == expected
        const expected_text: text = to_text(expected)
        const actual_text: text = to_text(actual)
        const message: text = test._join4("expected value different from ", expected_text, "; received ", actual_text)
        test.fail(message)
    end

    return
end

public func not_equal_text(actual: text, expected: text) -> void
    if actual == expected
        const message: text = test._join4("expected value different from ", expected, "; received ", actual)
        test.fail(message)
    end

    return
end
