-- Execução de processos externos e códigos de saída.
-- 🏗️ TIPOS
-- 🏗️ EXTERN C
-- 🚨 ERROS
namespace std.os.process

public struct ExitStatus
    code: int
end

public enum Error
    NotFound
    PermissionDenied
    IOFailure
    StillRunning
    Unknown
end

extern c
    func zt_host_process_run(program: text, args: list<text>, cwd: optional<text>) -> result<int, core.Error>
end

public func run(program: text, args: list<text> = [], cwd: optional<text> = none) -> result<int, core.Error>
    return process.zt_host_process_run(program, args, cwd)
end

public func run_program(program: text) -> result<int, core.Error>
    return process.run(program)
end

public func from_code(code: int) -> process.ExitStatus
    return process.ExitStatus(code: code)
end

public func exit_code(status: process.ExitStatus) -> int
    return status.code
end

public func is_success(status: process.ExitStatus) -> bool
    return status.code == 0
end

public func is_failure(status: process.ExitStatus) -> bool
    return status.code != 0
end
