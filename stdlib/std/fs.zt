-- Zenith Standard Library - FS Module
-- Synchronous filesystem operations (Decision 064).
namespace std.fs

public enum Error
    NotFound
    PermissionDenied
    AlreadyExists
    NotADirectory
    IsADirectory
    IOError
    InvalidPath
    Unknown
end

public struct Metadata
    size_bytes: int
    modified_at_ms: int
    created_at_ms: optional<int>
    is_file: bool
    is_dir: bool
end

extern c
    func zt_host_read_file(file_path: text) -> result<text, core.Error>
    func zt_host_write_file(file_path: text, content: text) -> result<void, core.Error>
    func zt_host_path_exists(target_path: text) -> bool
    func zt_host_fs_append_text_core(file_path: text, content: text) -> result<void, core.Error>
    func zt_host_fs_is_file_core(file_path: text) -> result<bool, core.Error>
    func zt_host_fs_is_dir_core(dir_path: text) -> result<bool, core.Error>
    func zt_host_fs_create_dir_core(dir_path: text) -> result<void, core.Error>
    func zt_host_fs_create_dir_all_core(dir_path: text) -> result<void, core.Error>
    func zt_host_fs_list_core(dir_path: text) -> result<list<text>, core.Error>
    func zt_host_fs_remove_file_core(file_path: text) -> result<void, core.Error>
    func zt_host_fs_remove_dir_core(dir_path: text) -> result<void, core.Error>
    func zt_host_fs_remove_dir_all_core(dir_path: text) -> result<void, core.Error>
    func zt_host_fs_copy_file_core(from_path: text, to_path: text) -> result<void, core.Error>
    func zt_host_fs_move_core(from_path: text, to_path: text) -> result<void, core.Error>
    func zt_host_fs_size_core(target_path: text) -> result<int, core.Error>
    func zt_host_fs_modified_at_core(target_path: text) -> result<int, core.Error>
    func zt_host_fs_created_at_core(target_path: text) -> result<optional<int>, core.Error>
end

func map_host_error(err: core.Error) -> fs.Error
    if err.code == "fs.not_found"
        return fs.Error.NotFound
    end

    if err.code == "fs.permission_denied"
        return fs.Error.PermissionDenied
    end

    if err.code == "fs.already_exists"
        return fs.Error.AlreadyExists
    end

    if err.code == "fs.not_a_directory"
        return fs.Error.NotADirectory
    end

    if err.code == "fs.is_a_directory"
        return fs.Error.IsADirectory
    end

    if err.code == "fs.invalid_path"
        return fs.Error.InvalidPath
    end

    if err.code == "fs.io"
        return fs.Error.IOError
    end

    if err.message == "No such file or directory" or err.message == "The system cannot find the file specified" or err.message == "The system cannot find the path specified"
        return fs.Error.NotFound
    end

    if err.message == "Permission denied" or err.message == "Access is denied."
        return fs.Error.PermissionDenied
    end

    return fs.Error.Unknown
end

public func read_text(file_path: text) -> result<text, fs.Error>
    match fs.zt_host_read_file(file_path)
        case success(value) ->
            return success(value)
        case error(err) ->
            return error(fs.map_host_error(err))
    end
end

public func write_text(file_path: text, content: text) -> result<void, fs.Error>
    match fs.zt_host_write_file(file_path, content)
        case success() ->
            return success()
        case error(err) ->
            return error(fs.map_host_error(err))
    end
end

public func append_text(file_path: text, content: text) -> result<void, fs.Error>
    match fs.zt_host_fs_append_text_core(file_path, content)
        case success() ->
            return success()
        case error(err) ->
            return error(fs.map_host_error(err))
    end
end

public func exists(target_path: text) -> result<bool, fs.Error>
    const val: bool = fs.zt_host_path_exists(target_path)
    return success(val)
end

public func is_file(file_path: text) -> result<bool, fs.Error>
