public func rename(from: text, to: text) -> result<void, fs.Error>
    return fs.move(from, to)
end

public func metadata(target_path: text) -> result<fs.Metadata, fs.Error>
    match fs.size(target_path)
        case success(meta_size) ->
            match fs.modified_at(target_path)
                case success(modified) ->
                    match fs.created_at(target_path)
                        case success(created) ->
                            match fs.is_file(target_path)
                                case success(file_flag) ->
                                    match fs.is_dir(target_path)
                                        case success(dir_flag) ->
                                            return success(fs.Metadata(
                                                size_bytes: meta_size,
                                                modified_at_ms: modified,
                                                created_at_ms: created,
                                                is_file: file_flag,
                                                is_dir: dir_flag
                                            ))
                                        case error(err) ->
                                            return error(err)
                                    end
                                case error(err) ->
                                    return error(err)
                            end
                        case error(err) ->
                            return error(err)
                    end
                case error(err) ->
                    return error(err)
            end
        case error(err) ->
            return error(err)
    end
end

public func size(target_path: text) -> result<int, fs.Error>
    match fs.zt_host_fs_size_core(target_path)
        case success(value) ->
