public func queue_int_new() -> list<int>
    return collections.zt_queue_i64_new()
end

public func queue_int_enqueue(queue: list<int>, value: int) -> list<int>
    return collections.zt_queue_i64_enqueue(queue, value)
end

public func queue_int_dequeue(queue: list<int>) -> collections.QueueNumberDequeueResult
    if len(queue) == 0
        return collections.QueueNumberDequeueResult(
            queue: queue,
            value: none
        )
    end

    return collections.QueueNumberDequeueResult(
        queue: queue[1..],
        value: collections.optional_number(queue[0])
    )
end

public func queue_int_peek(queue: list<int>) -> optional<int>
    return collections.zt_queue_i64_peek(queue)
end

public func queue_text_new() -> list<text>
    return collections.zt_queue_text_new()
end

public func queue_text_enqueue(queue: list<text>, value: text) -> list<text>
    return collections.zt_queue_text_enqueue(queue, value)
end

public func queue_text_dequeue(queue: list<text>) -> collections.QueueTextDequeueResult
    if len(queue) == 0
        return collections.QueueTextDequeueResult(
            queue: queue,
            value: none
        )
    end

    return collections.QueueTextDequeueResult(
        queue: queue[1..],
        value: collections.optional_text_value(queue[0])
    )
end

public func queue_text_peek(queue: list<text>) -> optional<text>
    return collections.zt_queue_text_peek(queue)
end

public func stack_int_new() -> list<int>
    return collections.zt_stack_i64_new()
end

public func stack_int_push(stack: list<int>, value: int) -> list<int>
    return collections.zt_stack_i64_push(stack, value)
end

public func stack_int_pop(stack: list<int>) -> collections.StackNumberPopResult
    const size: int = len(stack)

    if size == 0
        return collections.StackNumberPopResult(
            stack: stack,
            value: none
        )
    end

    if size == 1
        return collections.StackNumberPopResult(
            stack: collections.zt_stack_i64_new(),
            value: collections.optional_number(stack[0])
        )
    end

    return collections.StackNumberPopResult(
        stack: stack[0..(size - 2)],
        value: collections.optional_number(stack[size - 1])
    )
end

public func stack_int_peek(stack: list<int>) -> optional<int>
    return collections.zt_stack_i64_peek(stack)
end

public func stack_text_new() -> list<text>
    return collections.zt_stack_text_new()
end

public func stack_text_push(stack: list<text>, value: text) -> list<text>
    return collections.zt_stack_text_push(stack, value)
end

public func stack_text_pop(stack: list<text>) -> collections.StackTextPopResult
    const size: int = len(stack)

    if size == 0
        return collections.StackTextPopResult(
            stack: stack,
            value: none
        )
    end

    if size == 1
        return collections.StackTextPopResult(
            stack: collections.zt_stack_text_new(),
            value: collections.optional_text_value(stack[0])
        )
    end

    return collections.StackTextPopResult(
        stack: stack[0..(size - 2)],
        value: collections.optional_text_value(stack[size - 1])
    )
end

public func stack_text_peek(stack: list<text>) -> optional<text>
    return collections.zt_stack_text_peek(stack)
end

