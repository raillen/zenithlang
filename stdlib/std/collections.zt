namespace std.collections

public struct QueueNumberDequeueResult
    queue: list<int>
    value: optional<int>
end

public struct QueueTextDequeueResult
    queue: list<text>
    value: optional<text>
end

public struct StackNumberPopResult
    stack: list<int>
    value: optional<int>
end

public struct StackTextPopResult
    stack: list<text>
    value: optional<text>
end

func optional_number(value: int) -> optional<int>
    return value
end

func optional_text_value(value: text) -> optional<text>
    return value
end

