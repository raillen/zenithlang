-- Teste Fase 4: Operador ? (propagação de Outcome)
namespace test_try

-- Simula uma divisão segura que pode falhar
pub func divide(a: int, b: int) -> Outcome<int>
    if b == 0
        return Failure("divisao por zero")
    end
    return Success(a / b)
end

-- Usa o operador ? para propagar o erro automaticamente
pub func calcular(x: int, y: int) -> Outcome<int>
    var resultado: int = divide(x, y)?
    var dobro: int = resultado * 2
    return Success(dobro)
end

pub func main()
    -- Caso de sucesso
    var ok = calcular(10, 2)
    if ok is Outcome
        print("Sucesso: {ok}")
    end

    -- Caso de falha propagada
    var err = calcular(5, 0)
    if err is Outcome
        print("Erro: {err}")
    end

    -- Operador ! (bang/unwrap-or-panic)
    var val: int = Success(42)!
    print("Valor desempacotado: {val}")
end
