import std.io

pub func main()
    -- 1. Match Literal / Identificadores Simples
    var x = 42
    match x
        case 10 => io.println("Era 10")
        case 42 => io.println("Era 42! Literal match funciona.")
        case _  => io.println("Fallback hit!")
    end

    -- 2. Variantes / Outcomes e Optional (Destructuring)
    var resp: Outcome<text> = Success("Dados carregados com sucesso")
    match resp
        case Success(val) => io.println("Sucesso: " + val)
        case Failure(err) => io.println("Erro: " + err)
    end

    -- 3. Match com Guards e Captura
    var age = 15
    match age
        case n when n < 18 => io.println("Menor de idade!")
        case n when n >= 18 => io.println("Maior de idade!")
    end
end

main()
