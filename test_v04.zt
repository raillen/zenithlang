-- Teste das Funcionalidades Zenith v0.4 Sovereign

struct User
    name: text
    age: int
end

func get_user(id: int) -> Optional<User>
    if id == 1
        return Optional.Present(User { name: "Raillen", age: 25 })
    end
    return Optional.Empty
end

pub func main(args: list<text>)
    -- 1. Identificadores com ! e ?
    var ready? = true
    func save!()
        print("Salvando perigosamente...")
    end
    
    if ready?
        save!()
    end

    -- 2. Interpolação de Strings
    var name = "Zenith"
    var version = 0.4
    print("Bem-vindo ao {name} v{version}!")
    print("Soma: {1 + 2}")

    -- 3. Safe Navigation ?.
    var u = get_user(1)
    var name_safe = u?.name or "Anonimo"
    print("User: {name_safe}")
    
    var u2 = get_user(2)
    var name_none = u2?.name or "Desconhecido"
    print("User 2: {name_none}")

    -- 4. After (Defer)
    print("Inicio da tarefa")
    after print("Fim da tarefa (via after)")
    
    after do
        print("Limpando recursos...")
        print("Fechando conexoes...")
    end

    -- 5. Check
    func fail() -> Optional<text>
        return Optional.Empty
    end
    
    print("Antes do check")
    -- var x = check fail() -- Isso deve sair da função main se falhar
    -- print("Nao deve imprimir isso")
    
    -- 6. Namespace Automático
    -- (Verificado pela ausência de erro de compilação se o arquivo for inferido)
    
    print("Teste concluido com sucesso!")
end
