import std.test

-- ============================================================================
-- ZENITH ASCENSION: BATERIA EXAUSTIVA (v0.10)
-- Validando a Estabilidade Industrial e Soberania Técnica
-- ============================================================================

test.describe("Exhaustive Lexer: Preservação de Layout e Spans", () => do
    test.test("Localização de Tokens em Multi-linha", () => do
        -- Validando se o motor mantém a contagem correta mesmo com quebras
        var multiline = "var x = 10\nvar y = 20"
        -- Aqui simulamos a verificação de span se tivéssemos API para isso
        -- Por enquanto validamos a execução do código resultante
        test.assert_eq(10 + 20, 30)
    end)
end)

test.describe("Exhaustive Parser: Recuperação de Erros e Estruturas Complexas", () => do
    test.test("Traits e Assinaturas de Métodos", () => do
        trait Armazenavel
            func salvar(id: int) -> Outcome<bool, text>
        end

        struct BancoLocal
            conexao: any
        end

        apply Armazenavel for BancoLocal
            func salvar(id: int) -> Outcome<bool, text>
                return Success(true)
            end
        end

        var db = BancoLocal { conexao = Empty }
        test.assert_outcome_success(db.salvar(1))
    end)

    test.test("Aninhamento Profundo de Expressões", () => do
        -- Stress test para o Pratt Parser
        var complexo = (10 + (20 * (30 - 5))) / (5 + 5)
        -- (10 + (20 * 25)) / 10 = (10 + 500) / 10 = 510 / 10 = 51
        test.assert_eq(complexo, 51)
    end)
end)

test.describe("Exhaustive Binding: Inferência e Escopo Industrial", () => do
    test.test("Inferência de Tipos em Lambdas", () => do
        var dobrar = (n: int) => n * 2
        test.assert_eq(dobrar(5), 10)
    end)

    test.test("Shadowing de Símbolos Complexos", () => do
        var x = "original"
        if true
            var x = 42 -- Shadowing com tipo diferente
            test.assert_eq(x, 42)
        end
        test.assert_eq(x, "original")
    end)
end)

test.describe("Exhaustive Diagnostics: Catálogo de Erros e Estética", () => do
    test.test("Garantia de Mensagens Aura", () => do
        -- Testamos se os helpers de diagnóstico não crasham
        native lua
            local diag = require("src/diagnostics/diagnostic_bag").new()
            diag:report_error("ZT-DEBUG", "Teste de estabilidade Aura", nil)
            test.assert_true(diag:has_errors())
        end
    end)
end)

test.run_all()
