namespace app.main

import std.os as os

func platform_is_known(value: os.Platform) -> bool
    match value
        case os.Platform.Unknown ->
            return false
        case default ->
            return true
    end
end

func arch_is_known(value: os.Arch) -> bool
    match value
        case os.Arch.Unknown ->
            return false
        case default ->
            return true
    end
end

func main() -> result<void, os.Error>
    const current_pid: int = os.pid()
    if current_pid <= 0
        panic("std.os.pid should be positive")
    end

    const current_platform: os.Platform = os.platform()
    const current_arch: os.Arch = os.arch()

    if platform_is_known(current_platform) == false
        panic("std.os.platform returned Unknown")
    end

    if arch_is_known(current_arch) == false
        panic("std.os.arch returned Unknown")
    end

    const cwd: text = os.current_dir()?
    if len(cwd) == 0
        panic("std.os.current_dir returned empty text")
    end

    os.change_dir(cwd)?

    return success()
end
