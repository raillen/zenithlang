namespace app.main

import std.regex as regex

func expect_invalid(pattern: text) -> result<void, regex.Error>
    const compiled_result: result<regex.Regex, regex.Error> = regex.compile(pattern)
    match compiled_result
        case success(_compiled) ->
            return error(regex.Error.InvalidPattern)
        case error(_err) ->
            return success()
    end
end

func expect_first(value: optional<text>, expected: text) -> result<void, regex.Error>
    match value
        case some(actual) ->
            if actual != expected
                return error(regex.Error.InvalidPattern)
            end
            return success()
        case none ->
            return error(regex.Error.InvalidPattern)
    end
end

func expect_none(value: optional<text>) -> result<void, regex.Error>
    match value
        case some(_actual) ->
            return error(regex.Error.InvalidPattern)
        case none ->
            return success()
    end
end

func main() -> result<void, regex.Error>
    const compiled_result: result<regex.Regex, regex.Error> = regex.compile("^[A-Za-z]+[0-9]+$")
    const compiled: regex.Regex = compiled_result?

    if regex.is_valid("[A-Za-z]+") == false
        return error(regex.Error.InvalidPattern)
    end
    if regex.is_valid("[abc")
        return error(regex.Error.InvalidPattern)
    end

    if regex.is_match(compiled.pattern, "player123") == false
        return error(regex.Error.InvalidPattern)
    end
    if regex.contains(compiled.pattern, "player123") == false
        return error(regex.Error.InvalidPattern)
    end
    if regex.is_match(compiled.pattern, "123player")
        return error(regex.Error.InvalidPattern)
    end
    if regex.is_match("^colou?r$", "color") == false
        return error(regex.Error.InvalidPattern)
    end
    if regex.is_match("^colou?r$", "colour") == false
        return error(regex.Error.InvalidPattern)
    end
    if regex.is_match("a.c", "xxabcxx") == false
        return error(regex.Error.InvalidPattern)
    end

    const loose_match: bool = regex.matches("[A-Za-z]+", "abc123")?
    if loose_match == false
        return error(regex.Error.InvalidPattern)
    end

    const full_letters: bool = regex.full_match("[A-Za-z]+", "abc")?
    if full_letters == false
        return error(regex.Error.InvalidPattern)
    end

    const partial_letters: bool = regex.full_match("[A-Za-z]+", "abc123")?
    if partial_letters
        return error(regex.Error.InvalidPattern)
    end

    expect_first(regex.first("[0-9]+", "id=42 retry=7"), "42")?
    expect_none(regex.first("z+", "id=42"))?

    if regex.count("[0-9]+", "a12 b7 c345") != 3
        return error(regex.Error.InvalidPattern)
    end

    const matches: list<text> = regex.find_all("[0-9]+", "a12 b7 c345")
    if len(matches) != 3
        return error(regex.Error.InvalidPattern)
    end
    if matches[0] != "12" or matches[1] != "7" or matches[2] != "345"
        return error(regex.Error.InvalidPattern)
    end

    const parts: list<text> = regex.split("[,;]+", "red,green;blue")
    if len(parts) != 3
        return error(regex.Error.InvalidPattern)
    end
    if parts[0] != "red" or parts[1] != "green" or parts[2] != "blue"
        return error(regex.Error.InvalidPattern)
    end

    const replaced: text = regex.replace_all("[0-9]+", "a12 b7 c345", "N")
    if replaced != "aN bN cN"
        return error(regex.Error.InvalidPattern)
    end

    const escaped_pattern: text = regex.escape("a.c+")
    const escaped_match: bool = regex.full_match(escaped_pattern, "a.c+")?
    if escaped_match == false
        return error(regex.Error.InvalidPattern)
    end
    const escaped_nomatch: bool = regex.full_match(escaped_pattern, "abc")?
    if escaped_nomatch
        return error(regex.Error.InvalidPattern)
    end

    const invalid_result: result<void, regex.Error> = expect_invalid("[abc")
    invalid_result?

    return success()
end
