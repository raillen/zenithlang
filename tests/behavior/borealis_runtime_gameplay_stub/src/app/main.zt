namespace app.main

import borealis.game as game
import borealis.game.ai as ai
import borealis.game.animation as animation
import borealis.game.audio as audio
import borealis.game.camera as camera
import borealis.game.controllers as controllers
import borealis.game.contracts as contracts
import borealis.game.entities as entities
import borealis.game.input as input
import borealis.game.movement as movement
import borealis.game.procedural as procedural
import borealis.game.vehicles as vehicles
import borealis.game.world as world

func main() -> result<void, core.Error>
    verify_contracts_entities_and_movement()?
    verify_controllers_vehicles_and_animation()?
    verify_input_audio_ai_camera_world_and_procedural()?
    return success()
end

func verify_contracts_entities_and_movement() -> result<void, core.Error>
    const body0: contracts.Body2D = contracts.body2d(
        position: game.vec2(4.0, 6.0),
        velocity: game.vec2(3.0, 4.0)
    )
    if approx(contracts.body_speed(body0), 5.0) == false
        return error("contracts body_speed should preserve the classic 3-4-5 vector")
    end

    const body1: contracts.Body2D = contracts.body_translate(body0, game.vec2(2.0, -1.0))
    if approx(body1.position.x, 6.0) == false or approx(body1.position.y, 5.0) == false
        return error("contracts body_translate should move the body position")
    end

    const moved_point: game.Vector2 = movement.move(body1.position, game.vec2(5.0, 0.0))
    if moved_point.x <= body1.position.x
        return error("movement move should advance the point forward")
    end

    const player: entities.Entity = entities.entity_create("player")?
    const helper: entities.Entity = entities.entity_create("helper")?
    entities.entity_set_position(player, game.vec2(1.0, 2.0))?
    entities.entity_add_tag(player, "hero")?
    entities.entity_set_parent(helper, player)?

    const stable_id: text = entities.entity_get_id(player)
    const clone: entities.Entity = entities.entity_clone(player)?
    if entities.entity_get_name(clone) != "player"
        return error("entities clone should preserve the source name")
    end

    const info: entities.EntityInfo = entities.entity_inspect(player)
    if info.child_count != 1
        return error("entities inspect should expose the child count")
    end

    const maybe_found: optional<entities.Entity> = entities.entity_find_stable_id(stable_id)
    match maybe_found
        case value found ->
            if found.id != player.id
                return error("entities find_stable_id should resolve the original entity")
            end
        case none ->
            return error("entities find_stable_id should find the stored stable id")
    end

    entities.entity_clear_dirty(player)?
    if entities.entity_is_dirty(player)
        return error("entities clear_dirty should clear the dirty flag")
    end

    return success()
end

func verify_controllers_vehicles_and_animation() -> result<void, core.Error>
    var grid: controllers.Controller = controllers.grid_create(contracts.body2d())
    grid = controllers.controller_update(grid, contracts.ActionInput(right: true))
    if grid.body.position.x <= 0.0
        return error("controllers grid should step to the right")
    end

    var platform: controllers.Controller = controllers.platform_create(
        contracts.body2d(position: game.vec2(0.0, -10.0))
    )
    platform = controllers.controller_update(platform, contracts.ActionInput(jump: true), dt: 1.0 / 60.0)
    if platform.grounded
        return error("controllers platform should leave the ground after jump")
    end
    if controllers.controller_visual_state(platform) != "jump"
        return error("controllers should sync jump state for airborne platform movement")
    end

    var car: vehicles.CarState = vehicles.car_create(vehicles.CarConfig(max_speed: 400.0))
    car = vehicles.car_accelerate(car, 25.0)
    car = vehicles.car_boost(car, 80.0, 1.0)
    car = vehicles.car_set_grip(car, 0.8)
    if car.speed <= 0.0
        return error("vehicles car_accelerate should increase the car speed")
    end
    if car.boost_timer <= 0.0
        return error("vehicles car_boost should store the boost window")
    end
    if approx(car.grip, 0.8) == false
        return error("vehicles car_set_grip should update the grip state")
    end

    var bindings: animation.AnimationMap = animation.animation_map_create()
    bindings = animation.animation_map_set(bindings, "idle", animation.animation_create("idle", frame_total: 4))
    bindings = animation.animation_map_set(bindings, "move", animation.animation_create("run", frame_total: 6))

    var state: animation.AnimationState = animation.animation_create("idle", fps: 10.0, frame_total: 4)
    state = animation.animation_sync(state, bindings, "move")
    state = animation.animation_play(state)
    state = animation.animation_set_frame(state, 2)
    state = animation.animation_flip(state, true)

    if state.clip != "run"
        return error("animation sync should switch to the mapped clip")
    end
    if state.frame <= 0
        return error("animation set_frame should advance the current frame")
    end
    if state.flip_x == false
        return error("animation flip should mirror the sprite state")
    end

    return success()
end

func verify_input_audio_ai_camera_world_and_procedural() -> result<void, core.Error>
    input.input_context_create("gameplay")?
    input.input_context_push("gameplay")?
    input.action_bind("jump", "gamepad_south", context: "gameplay")?
    input.action_bind("move_left", "left", context: "gameplay")?
    input.action_bind("move_right", "right", context: "gameplay")?
    input.axis_bind("move_x", "move_left", "move_right")?

    const frame: input.InputFrame = input.input_frame(
        down: contracts.ActionInput(right: true),
        pressed: contracts.ActionInput(jump: true),
        released: contracts.action_input(),
        mouse: contracts.mouse_state(
            position: game.vec2(10.0, 10.0),
            left_pressed: true,
            left_down: true
        ),
        gamepad: contracts.gamepad_state(
            left_axis: game.vec2(0.8, 0.0),
            south_pressed: true,
            south_down: true
        )
    )

    if input.action_pressed(frame, "jump") == false
        return error("input action_pressed should read the active gameplay binding")
    end
    if approx(input.axis_get(frame, "move_x"), 1.0) == false
        return error("input axis_get should combine bound actions into a signed axis")
    end
    if input.mouse_hover_state(frame.mouse, game.rect(0.0, 0.0, 20.0, 20.0)) == false
        return error("input mouse_hover_state should use the shared mouse contract")
    end
    if input.input_any_pressed(frame) == false
        return error("input input_any_pressed should detect an active frame")
    end

    const recording_id: int = input.input_record(frame)
    const maybe_playback: optional<input.InputFrame> = input.input_playback(recording_id)
    match maybe_playback
        case value playback ->
            if playback.gamepad.south_down == false
                return error("input playback should preserve recorded frame content")
            end
        case none ->
            return error("input playback should recover a recorded frame")
    end

    input.input_lock()
    if input.action_down(frame, "jump")
        return error("input lock should suppress bound actions")
    end
    input.input_unlock()

    verify_audio_ai_camera()?
    verify_world_and_procedural()?

    const maybe_context: optional<text> = input.input_context_pop()
    match maybe_context
        case value current ->
            if current != "gameplay"
                return error("input context_pop should return the active context name")
            end
        case none ->
            return error("input context_pop should return the pushed context")
    end

    return success()
end

func verify_audio_ai_camera() -> result<void, core.Error>
    const group: audio.AudioGroup = audio.audio_group_create("sfx")?
    const sound: audio.Sound = audio.sound_load("jump.wav")?
    const music: audio.Music = audio.music_load("theme.ogg")?

    audio.audio_set_master_volume(0.8)
    audio.audio_group_set_volume(group, 0.5)?
    audio.sound_set_volume(sound, 0.5)?
    audio.sound_route(sound, group)?
    audio.sound_play_loaded(sound)?
    if audio.audio_is_playing(sound) == false
        return error("audio sound_play_loaded should mark the sound as playing")
    end
    if approx(audio.sound_effective_volume(sound), 0.2) == false
        return error("audio effective volume should combine master, group and local volume")
    end

    audio.music_set_volume(music, 0.75)?
    audio.music_play_loaded(music)?
    if approx(audio.music_effective_volume(music), 0.6) == false
        return error("audio music_effective_volume should include the master volume")
    end
    audio.music_pause(music)?
    audio.music_resume(music)?

    const route: ai.PatrolRoute = ai.patrol_route(game.vec2(0.0, 0.0), game.vec2(10.0, 0.0))
    if route.point_b.x <= route.point_a.x
        return error("ai patrol_route should keep both patrol points")
    end

    const random_step: game.Vector2 = ai.move_randomly(game.vec2(0.0, 0.0), 4.0, 0)
    if random_step.x <= 0.0
        return error("ai move_randomly should move on a deterministic phase")
    end

    const sight: ai.SensorHit = ai.vision_sensor(
        game.vec2(0.0, 0.0),
        0.0,
        game.vec2(5.0, 0.0),
        90.0,
        10.0
    )
    if sight.detected == false
        return error("ai vision_sensor should detect targets inside the cone")
    end

    var fsm: ai.FiniteStateMachine = ai.fsm_create("idle")
    fsm = ai.fsm_set_state(fsm, "chase")
    fsm = ai.fsm_update(fsm, dt: 0.5)
    if fsm.state != "chase" or fsm.ticks != 1
        return error("ai fsm should change state and count updates")
    end

    var tree: ai.BehaviorTree = ai.bt_create()
    tree = ai.bt_start(tree, "attack")
    tree = ai.bt_succeed(tree)
    if tree.succeeded == false or tree.running
        return error("ai behavior tree helpers should expose success state")
    end

    var rig: camera.CameraRig = camera.camera_rig_create()
    rig = camera.camera_set_deadzone(rig, camera.camera_deadzone(10.0, 10.0))
    rig = camera.camera_set_look_ahead(rig, game.vec2(2.0, 0.0))
    rig = camera.camera_set_bounds(
        rig,
        camera.CameraBounds(min_x: -5.0, min_y: -5.0, max_x: 20.0, max_y: 20.0)
    )
    rig = camera.camera_follow_rig(rig, game.vec2(30.0, 0.0), smooth: 1.0)
    rig = camera.camera_shake(rig, 1.5, 0.2)
    rig = camera.camera_step(rig, 1, dt: 0.1)

    const resolved_center: game.Vector2 = camera.camera_resolve_center(rig)
    if resolved_center.x > 20.0
        return error("camera bounds should clamp the resolved camera center")
    end

    const framing: camera.CameraFraming = camera.camera_frame_targets(
        game.vec2(0.0, 0.0),
        game.vec2(100.0, 0.0),
        padding: 0.0
    )
    if framing.zoom <= 0.0
        return error("camera framing should return a positive zoom")
    end

    return success()
end

func verify_world_and_procedural() -> result<void, core.Error>
    const tileset: world.Tileset = world.tileset_load("terrain.png", tile_width: 16, tile_height: 16, tile_count: 8)?
    if world.tileset_tile_count(tileset) != 8
        return error("world tileset should keep the declared tile count")
    end

    const map_a: world.TileMap = world.map_create(6, 6, 32.0)?
    world.map_set_tile(map_a, 2, 2, world.tile(index: 7, solid: true, walkable: false))?
    world.map_set_tile_index(map_a, 1, 1, 3)?
    if world.map_get_tile_index(map_a, 1, 1) != 3
        return error("world map_set_tile_index should preserve the selected tile index")
    end

    if world.tile_neighbor_count(map_a, 1, 1) != 4
        return error("world tile_neighbor_count should expose the four cardinal neighbors inside bounds")
    end

    const path: world.PathResult = world.map_find_path(map_a, 0, 0, 5, 0)
    if path.reachable == false or path.next_x != 1
        return error("world map_find_path should expose the first reachable step")
    end

    if world.map_build_collision(map_a) != 1
        return error("world map_build_collision should count solid tiles")
    end

    const map_b: world.TileMap = world.map_clone(map_a)?
    if world.map_get_tile_index(map_b, 1, 1) != 3
        return error("world map_clone should copy tile data into the new map")
    end

    procedural.set_seed(42)
    const float_pick: float = procedural.range_float(0.25, 0.75)
    if approx(float_pick, 0.25) == false and approx(float_pick, 0.75) == false
        return error("procedural range_float should stay inside the requested bounds")
    end

    const sample: float = procedural.noise_sample(procedural.noise_create(scale: 4, octaves: 2), 3, 5)
    if sample < 0.0 or sample > 1.0
        return error("procedural noise_sample should normalize values between zero and one")
    end

    const generated: world.TileMap = procedural.pipeline_generate_map(
        procedural.pipeline_create("platforms", 8, 6)
    )?
    if world.map_is_solid(generated, 0, 5) == false
        return error("procedural platforms pipeline should create a solid floor")
    end

    const cellular: world.TileMap = procedural.cellular_automata_generate(6, 6, 1)?
    if world.map_width(cellular) != 6 or world.map_height(cellular) != 6
        return error("procedural cellular automata should preserve the requested map size")
    end

    return success()
end

func approx(left: float, right: float, epsilon: float = 0.001) -> bool
    var diff: float = left - right
    if diff < 0.0
        diff = 0.0 - diff
    end
    return diff <= epsilon
end
