namespace borealis.game.movement

extern c
    func zt_math_sqrt(value: float) -> float
end

public func move(position: game.Vector2, delta: game.Vector2) -> game.Vector2
    return game.vec2(position.x + delta.x, position.y + delta.y)
end

public func push(position: game.Vector2, force: game.Vector2, dt: float = 1.0 / 60.0) -> game.Vector2
    return game.vec2(position.x + (force.x * dt), position.y + (force.y * dt))
end

public func teleport(_position: game.Vector2, target: game.Vector2) -> game.Vector2
    return target
end

public func vector_length(value: game.Vector2) -> float
    return movement.zt_math_sqrt((value.x * value.x) + (value.y * value.y))
end

public func normalize(value: game.Vector2) -> game.Vector2
    const length: float = movement.vector_length(value)
    if length <= 0.0
        return game.vec2(0.0, 0.0)
    end
    return game.vec2(value.x / length, value.y / length)
end

public func move_towards(current: game.Vector2, target: game.Vector2, speed: float, dt: float = 1.0 / 60.0) -> game.Vector2
    const step: float = speed * dt
    var next_x: float = current.x
    var next_y: float = current.y

    if target.x > current.x
        next_x = current.x + step
        if next_x > target.x
            next_x = target.x
        end
    end

    if target.x < current.x
        next_x = current.x - step
        if next_x < target.x
            next_x = target.x
        end
    end

    if target.y > current.y
        next_y = current.y + step
        if next_y > target.y
            next_y = target.y
        end
    end

    if target.y < current.y
        next_y = current.y - step
        if next_y < target.y
            next_y = target.y
        end
    end

    return game.vec2(next_x, next_y)
end

public func dash(position: game.Vector2, direction: game.Vector2, speed: float, duration: float) -> game.Vector2
    const unit: game.Vector2 = movement.normalize(direction)
    return movement.move(position, game.vec2(unit.x * speed * duration, unit.y * speed * duration))
end

public func entity_move(entity: entities.Entity, delta: game.Vector2) -> result<void, core.Error>
    const current: game.Vector2 = entities.entity_get_position(entity)
    return entities.entity_set_position(entity, movement.move(current, delta))
end

public func entity_push(
    entity: entities.Entity,
    force: game.Vector2,
    dt: float = 1.0 / 60.0
) -> result<void, core.Error>
    const current: game.Vector2 = entities.entity_get_position(entity)
    return entities.entity_set_position(entity, movement.push(current, force, dt))
end

public func entity_teleport(entity: entities.Entity, target: game.Vector2) -> result<void, core.Error>
    return entities.entity_set_position(entity, target)
end

public func entity_set_rotation(entity: entities.Entity, angle: float) -> result<void, core.Error>
    return entities.entity_set_rotation(entity, angle)
end

public func body_move(body: contracts.Body2D, delta: game.Vector2) -> contracts.Body2D
    const next_position: game.Vector2 = movement.move(body.position, delta)
    return contracts.Body2D(position: next_position, velocity: body.velocity)
end

public func body_push(body: contracts.Body2D, force: game.Vector2, dt: float = 1.0 / 60.0) -> contracts.Body2D
    const next_velocity: game.Vector2 = movement.push(body.velocity, force, dt)
    return contracts.Body2D(position: body.position, velocity: next_velocity)
end

public func body_teleport(body: contracts.Body2D, target: game.Vector2) -> contracts.Body2D
    return contracts.Body2D(position: target, velocity: body.velocity)
end

public func body_dash(
    body: contracts.Body2D,
    direction: game.Vector2,
    speed: float,
    duration: float
) -> contracts.Body2D
    return contracts.Body2D(
        position: movement.dash(body.position, direction, speed, duration),
        velocity: body.velocity
    )
end

public func body_step(body: contracts.Body2D, dt: float = 1.0 / 60.0) -> contracts.Body2D
    return contracts.body_integrate(body, dt)
end
