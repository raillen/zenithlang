namespace borealis.game.animation

public struct AnimationState
    clip: text = ""
    frame: int = 0
    frame_total: int = 1
    fps: float = 12.0
    speed_scale: float = 1.0
    playing: bool = false
    loop: bool = true
    elapsed: float = 0.0
    flip_x: bool = false
    flip_y: bool = false
    visual_state: text = "idle"
end

public struct AnimationMap
    idle_clip: text = ""
    move_clip: text = ""
    jump_clip: text = ""
    fall_clip: text = ""
    custom_blob: text = "|"
end

public func animation_create(
    clip: text,
    fps: float = 12.0,
    loop: bool = true,
    frame_total: int = 1
) -> animation.AnimationState
    return animation.AnimationState(
        clip: clip,
        frame: 0,
        frame_total: frame_total,
        fps: fps,
        speed_scale: 1.0,
        playing: false,
        loop: loop,
        elapsed: 0.0,
        flip_x: false,
        flip_y: false,
        visual_state: "idle"
    )
end

public func animation_play(state: animation.AnimationState) -> animation.AnimationState
    var next: animation.AnimationState = state
    next.playing = true
    return next
end

public func animation_stop(state: animation.AnimationState) -> animation.AnimationState
    var next: animation.AnimationState = state
    next.playing = false
    return next
end

public func animation_set_speed(state: animation.AnimationState, speed: float) -> animation.AnimationState
    var next: animation.AnimationState = state
    next.speed_scale = speed
    return next
end

public func animation_set_frame(state: animation.AnimationState, frame: int) -> animation.AnimationState
    var next: animation.AnimationState = state
    if frame < 0
        next.frame = 0
        return next
    end

    const max_frame: int = animation.animation_frame_count(state) - 1
    if frame > max_frame
        next.frame = max_frame
        return next
    end

    next.frame = frame
    return next
end

public func animation_set_loop(state: animation.AnimationState, loop: bool) -> animation.AnimationState
    var next: animation.AnimationState = state
    next.loop = loop
    return next
end

public func animation_flip(
    state: animation.AnimationState,
    flip_x: bool,
    flip_y: bool = false
) -> animation.AnimationState
    var next: animation.AnimationState = state
    next.flip_x = flip_x
    next.flip_y = flip_y
    return next
end

public func animation_is_playing(state: animation.AnimationState) -> bool
    return state.playing
end

public func animation_current_clip(state: animation.AnimationState) -> text
    return state.clip
end

public func animation_frame_count(state: animation.AnimationState) -> int
    if state.frame_total <= 0
        return 1
    end
    return state.frame_total
end

public func animation_update(
    state: animation.AnimationState,
    frame_count: int = 0,
    dt: float = 1.0 / 60.0
) -> animation.AnimationState
    if state.playing == false
        return state
    end

    var effective_frame_count: int = frame_count
    if effective_frame_count <= 0
        effective_frame_count = animation.animation_frame_count(state)
    end
    if effective_frame_count <= 0
        return state
    end
    if state.fps <= 0.0 or state.speed_scale <= 0.0
        return state
    end

    var next: animation.AnimationState = state
    next.elapsed = next.elapsed + dt

    const frame_time: float = 1.0 / (state.fps * state.speed_scale)
    while next.elapsed >= frame_time
        next.elapsed = next.elapsed - frame_time
        next.frame = next.frame + 1

        if next.frame >= effective_frame_count
            if next.loop
                next.frame = 0
            else
                next.frame = effective_frame_count - 1
                next.playing = false
                return next
            end
        end
    end

    return next
end

public func animation_map_create() -> animation.AnimationMap
    return animation.AnimationMap()
end

public func animation_map_set(
    current: animation.AnimationMap,
    state: text,
    value: animation.AnimationState
) -> animation.AnimationMap
    var next: animation.AnimationMap = current
    if state == "idle"
        next.idle_clip = value.clip
        return next
    end
    if state == "move"
        next.move_clip = value.clip
        return next
    end
    if state == "jump"
        next.jump_clip = value.clip
        return next
    end
    if state == "fall"
        next.fall_clip = value.clip
        return next
    end

    next.custom_blob = text.join([next.custom_blob, state, "=", value.clip, "|"])
    return next
end

public func animation_map_clip(current: animation.AnimationMap, state: text) -> text
    if state == "idle"
        return current.idle_clip
    end
    if state == "move"
        return current.move_clip
    end
    if state == "jump"
        return current.jump_clip
    end
    if state == "fall"
        return current.fall_clip
    end

    const needle: text = text.join(["|", state, "="])
    const start_index: int = text.index_of(current.custom_blob, needle)
    if start_index < 0
        return ""
    end

    var cursor: int = start_index + len(needle)
    var clip: text = ""
    while cursor < len(current.custom_blob)
        if current.custom_blob[cursor] == "|"
            return clip
        end
        clip = text.join([clip, current.custom_blob[cursor]])
        cursor = cursor + 1
    end
    return clip
end

public func animation_sync(
    state: animation.AnimationState,
    bindings: animation.AnimationMap,
    visual_state: text
) -> animation.AnimationState
    const target_clip: text = animation.animation_map_clip(bindings, visual_state)
    if target_clip == ""
        return state
    end

    var next: animation.AnimationState = state
    if next.clip != target_clip or next.visual_state != visual_state
        next.clip = target_clip
        next.frame = 0
        next.elapsed = 0.0
        next.playing = true
    end
    next.visual_state = visual_state
    return next
end
