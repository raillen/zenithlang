namespace borealis.game.world

public struct Tile
    index: int = 0
    solid: bool = false
    walkable: bool = true
end

public struct Tileset
    id: int
    path: text
    tile_width: int
    tile_height: int
    tile_count: int
end

public struct TileMap
    id: int
end

public struct PathResult
    reachable: bool = false
    next_x: int = 0
    next_y: int = 0
    length: int = 0
end

public var world_tile_solid: map<int, bool> = {}
public var world_tile_walkable: map<int, bool> = {}

public var world_tileset_next_id: int = 1
public var world_tileset_path: map<int, text> = {}
public var world_tileset_tile_width: map<int, int> = {}
public var world_tileset_tile_height: map<int, int> = {}
public var world_tileset_tile_count: map<int, int> = {}

public var world_map_next_id: int = 1
public var world_map_width: map<int, int> = {}
public var world_map_height: map<int, int> = {}
public var world_map_tile_size: map<int, float> = {}
public var world_map_spawn_x: map<int, float> = {}
public var world_map_spawn_y: map<int, float> = {}
public var world_map_default_index: map<int, int> = {}
public var world_map_default_solid: map<int, bool> = {}
public var world_map_default_walkable: map<int, bool> = {}
public var world_map_tile_index: map<text, int> = {}
public var world_map_tile_solid: map<text, bool> = {}
public var world_map_tile_walkable: map<text, bool> = {}

public func tile(index: int = 0, solid: bool = false, walkable: bool = true) -> world.Tile
    return world.Tile(index: index, solid: solid, walkable: walkable)
end

public func tile_key(x: int, y: int) -> int
    return (x * 100000) + y
end

public func map_key(target: world.TileMap, x: int, y: int) -> text
    return text.join(["m", format.hex(target.id), ":", format.hex(x), ":", format.hex(y)])
end

public func set_solid(x: int, y: int, value: bool) -> result<void, core.Error>
    var next: map<int, bool> = world_tile_solid
    next[world.tile_key(x, y)] = value
    world_tile_solid = next
    return success()
end

public func is_solid(x: int, y: int) -> bool
    const maybe: optional<bool> = world_tile_solid.get(world.tile_key(x, y))
    match maybe
        case value present ->
            return present
        case none ->
            return false
    end
end

public func set_walkable(x: int, y: int, value: bool) -> result<void, core.Error>
    var next: map<int, bool> = world_tile_walkable
    next[world.tile_key(x, y)] = value
    world_tile_walkable = next
    return success()
end

public func is_walkable(x: int, y: int) -> bool
    const maybe: optional<bool> = world_tile_walkable.get(world.tile_key(x, y))
    match maybe
        case value present ->
            return present
        case none ->
            return true
    end
end

public func tileset_load(
    path: text,
    tile_width: int = 32,
    tile_height: int = 32,
    tile_count: int = 0
) -> result<world.Tileset, core.Error>
    if path == ""
        return error("world: tileset path cannot be empty")
    end

    const id: int = world_tileset_next_id
    world_tileset_next_id = world_tileset_next_id + 1
    var next_path: map<int, text> = world_tileset_path
    next_path[id] = path
    world_tileset_path = next_path

    var next_tile_width: map<int, int> = world_tileset_tile_width
    next_tile_width[id] = tile_width
    world_tileset_tile_width = next_tile_width

    var next_tile_height: map<int, int> = world_tileset_tile_height
    next_tile_height[id] = tile_height
    world_tileset_tile_height = next_tile_height

    var next_tile_count: map<int, int> = world_tileset_tile_count
    next_tile_count[id] = tile_count
    world_tileset_tile_count = next_tile_count

    return success(world.Tileset(
        id: id,
        path: path,
        tile_width: tile_width,
        tile_height: tile_height,
        tile_count: tile_count
    ))
end

public func tileset_get_tile(tileset: world.Tileset, index: int) -> world.Tile
    if index < 0
        return world.tile()
    end
    if tileset.tile_count > 0 and index >= tileset.tile_count
        return world.tile()
    end
    return world.tile(index: index, solid: false, walkable: true)
end

public func tileset_tile_count(tileset: world.Tileset) -> int
    return tileset.tile_count
end

public func map_create(
    width: int,
    height: int,
    tile_size: float = 32.0,
    fill: world.Tile = world.Tile()
) -> result<world.TileMap, core.Error>
    if width <= 0 or height <= 0
        return error("world: map size must be positive")
    end

    const id: int = world_map_next_id
    world_map_next_id = world_map_next_id + 1
    var next_width: map<int, int> = world_map_width
    next_width[id] = width
    world_map_width = next_width

    var next_height: map<int, int> = world_map_height
    next_height[id] = height
    world_map_height = next_height

    var next_tile_size: map<int, float> = world_map_tile_size
    next_tile_size[id] = tile_size
    world_map_tile_size = next_tile_size

    var next_spawn_x: map<int, float> = world_map_spawn_x
    next_spawn_x[id] = 0.0
    world_map_spawn_x = next_spawn_x

    var next_spawn_y: map<int, float> = world_map_spawn_y
    next_spawn_y[id] = 0.0
    world_map_spawn_y = next_spawn_y

    var next_default_index: map<int, int> = world_map_default_index
    next_default_index[id] = fill.index
    world_map_default_index = next_default_index

    var next_default_solid: map<int, bool> = world_map_default_solid
    next_default_solid[id] = fill.solid
    world_map_default_solid = next_default_solid

    var next_default_walkable: map<int, bool> = world_map_default_walkable
    next_default_walkable[id] = fill.walkable
    world_map_default_walkable = next_default_walkable
    return success(world.TileMap(id: id))
end

public func map_width(target: world.TileMap) -> int
    return world.int_or(world_map_width, target.id, 0)
end

public func map_height(target: world.TileMap) -> int
    return world.int_or(world_map_height, target.id, 0)
end

public func map_tile_size(target: world.TileMap) -> float
    return world.float_or(world_map_tile_size, target.id, 32.0)
end

public func map_set_tile(target: world.TileMap, x: int, y: int, tile: world.Tile) -> result<void, core.Error>
    if world.map_in_bounds(target, x, y) == false
        return error("world: tile position out of bounds")
    end

    const key: text = world.map_key(target, x, y)
    var next_index: map<text, int> = world_map_tile_index
    next_index[key] = tile.index
    world_map_tile_index = next_index

    var next_solid: map<text, bool> = world_map_tile_solid
    next_solid[key] = tile.solid
    world_map_tile_solid = next_solid

    var next_walkable: map<text, bool> = world_map_tile_walkable
    next_walkable[key] = tile.walkable
    world_map_tile_walkable = next_walkable
    return success()
end

public func map_get_tile(target: world.TileMap, x: int, y: int) -> world.Tile
    if world.map_in_bounds(target, x, y) == false
        return world.tile()
    end

    const key: text = world.map_key(target, x, y)
    return world.Tile(
        index: world.int_text_or(world_map_tile_index, key, world.int_or(world_map_default_index, target.id, 0)),
        solid: world.bool_text_or(world_map_tile_solid, key, world.bool_or(world_map_default_solid, target.id, false)),
        walkable: world.bool_text_or(world_map_tile_walkable, key, world.bool_or(world_map_default_walkable, target.id, true))
    )
end

public func map_set_tile_index(target: world.TileMap, x: int, y: int, index: int) -> result<void, core.Error>
    const current: world.Tile = world.map_get_tile(target, x, y)
    return world.map_set_tile(target, x, y, world.Tile(index: index, solid: current.solid, walkable: current.walkable))
end

public func map_get_tile_index(target: world.TileMap, x: int, y: int) -> int
    return world.map_get_tile(target, x, y).index
end

public func map_is_solid(target: world.TileMap, x: int, y: int) -> bool
    return world.map_get_tile(target, x, y).solid
end

public func map_is_walkable(target: world.TileMap, x: int, y: int) -> bool
    return world.map_get_tile(target, x, y).walkable
end

public func tile_set_solid(tile: world.Tile, value: bool) -> world.Tile
    var next: world.Tile = tile
    next.solid = value
    return next
end

public func tile_set_walkable(tile: world.Tile, value: bool) -> world.Tile
    var next: world.Tile = tile
    next.walkable = value
    return next
end

public func tile_set_index(tile: world.Tile, value: int) -> world.Tile
    var next: world.Tile = tile
    next.index = value
    return next
end

public func tile_is_empty(tile: world.Tile) -> bool
    return tile.index == 0 and tile.solid == false
end

public func tile_is_blocking(tile: world.Tile) -> bool
    return tile.solid or tile.walkable == false
end

public func world_to_tile(position: game.Vector2, tile_size: float = 32.0) -> game.Point2
    return game.point2(position.x / tile_size, position.y / tile_size)
end

public func tile_to_world(tile: game.Point2, tile_size: float = 32.0) -> game.Vector2
    return game.vec2(tile.x * tile_size, tile.y * tile_size)
end

public func tile_neighbor_count(target: world.TileMap, x: int, y: int) -> int
    var total: int = 0
    if world.map_in_bounds(target, x - 1, y)
        total = total + 1
    end
    if world.map_in_bounds(target, x + 1, y)
        total = total + 1
    end
    if world.map_in_bounds(target, x, y - 1)
        total = total + 1
    end
    if world.map_in_bounds(target, x, y + 1)
        total = total + 1
    end
    return total
end

public func solid_neighbor_count(target: world.TileMap, x: int, y: int) -> int
    var total: int = 0
    if world.map_in_bounds(target, x - 1, y) and world.map_is_solid(target, x - 1, y)
        total = total + 1
    end
    if world.map_in_bounds(target, x + 1, y) and world.map_is_solid(target, x + 1, y)
        total = total + 1
    end
    if world.map_in_bounds(target, x, y - 1) and world.map_is_solid(target, x, y - 1)
        total = total + 1
    end
    if world.map_in_bounds(target, x, y + 1) and world.map_is_solid(target, x, y + 1)
        total = total + 1
    end
    return total
end

public func map_region_count(
    target: world.TileMap,
    start_x: int,
    start_y: int,
    width: int,
    height: int
) -> int
    var total: int = 0
    var y: int = start_y
    while y < (start_y + height)
        var x: int = start_x
        while x < (start_x + width)
            if world.map_in_bounds(target, x, y)
                total = total + 1
            end
            x = x + 1
        end
        y = y + 1
    end
    return total
end

public func map_build_collision(target: world.TileMap) -> int
    var total: int = 0
    var y: int = 0
    while y < world.map_height(target)
        var x: int = 0
        while x < world.map_width(target)
            if world.map_is_solid(target, x, y)
                total = total + 1
            end
            x = x + 1
        end
        y = y + 1
    end
    return total
end

public func map_set_spawn_point(target: world.TileMap, point: game.Vector2) -> result<void, core.Error>
    var next_spawn_x: map<int, float> = world_map_spawn_x
    next_spawn_x[target.id] = point.x
    world_map_spawn_x = next_spawn_x

    var next_spawn_y: map<int, float> = world_map_spawn_y
    next_spawn_y[target.id] = point.y
    world_map_spawn_y = next_spawn_y
    return success()
end

public func map_get_spawn_point(target: world.TileMap) -> game.Vector2
    return game.vec2(
        world.float_or(world_map_spawn_x, target.id, 0.0),
        world.float_or(world_map_spawn_y, target.id, 0.0)
    )
end

public func map_clear(target: world.TileMap) -> result<void, core.Error>
    var y: int = 0
    while y < world.map_height(target)
        var x: int = 0
        while x < world.map_width(target)
            world.map_set_tile(
                target,
                x,
                y,
                world.tile(
                    index: world.int_or(world_map_default_index, target.id, 0),
                    solid: world.bool_or(world_map_default_solid, target.id, false),
                    walkable: world.bool_or(world_map_default_walkable, target.id, true)
                )
            )?
            x = x + 1
        end
        y = y + 1
    end
    return success()
end

public func map_clone(target: world.TileMap) -> result<world.TileMap, core.Error>
    const clone_map: world.TileMap = world.map_create(
        world.map_width(target),
        world.map_height(target),
        world.map_tile_size(target),
        world.tile(
            index: world.int_or(world_map_default_index, target.id, 0),
            solid: world.bool_or(world_map_default_solid, target.id, false),
            walkable: world.bool_or(world_map_default_walkable, target.id, true)
        )
    )?

    var y: int = 0
    while y < world.map_height(target)
        var x: int = 0
        while x < world.map_width(target)
            world.map_set_tile(clone_map, x, y, world.map_get_tile(target, x, y))?
            x = x + 1
        end
        y = y + 1
    end

    world.map_set_spawn_point(clone_map, world.map_get_spawn_point(target))?
    return success(clone_map)
end

public func map_find_path(
    target: world.TileMap,
    start_x: int,
    start_y: int,
    goal_x: int,
    goal_y: int
) -> world.PathResult
    if world.map_in_bounds(target, start_x, start_y) == false
        return world.PathResult(reachable: false, next_x: start_x, next_y: start_y, length: 0)
    end
    if world.map_in_bounds(target, goal_x, goal_y) == false
        return world.PathResult(reachable: false, next_x: start_x, next_y: start_y, length: 0)
    end
    if world.map_is_walkable(target, goal_x, goal_y) == false
        return world.PathResult(reachable: false, next_x: start_x, next_y: start_y, length: 0)
    end

    var current_x: int = start_x
    var current_y: int = start_y
    var next_x: int = start_x
    var next_y: int = start_y
    var length: int = 0

    while current_x != goal_x or current_y != goal_y
        var candidate_x: int = current_x
        var candidate_y: int = current_y

        if goal_x > current_x
            candidate_x = current_x + 1
        end
        if goal_x < current_x
            candidate_x = current_x - 1
        end
        if candidate_x == current_x
            if goal_y > current_y
                candidate_y = current_y + 1
            end
            if goal_y < current_y
                candidate_y = current_y - 1
            end
        end

        if world.map_is_walkable(target, candidate_x, candidate_y) == false
            return world.PathResult(reachable: false, next_x: next_x, next_y: next_y, length: length)
        end

        current_x = candidate_x
        current_y = candidate_y
        if length == 0
            next_x = current_x
            next_y = current_y
        end
        length = length + 1

        if length > (world.map_width(target) * world.map_height(target))
            return world.PathResult(reachable: false, next_x: next_x, next_y: next_y, length: length)
        end
    end

    return world.PathResult(reachable: true, next_x: next_x, next_y: next_y, length: length)
end

public func map_in_bounds(target: world.TileMap, x: int, y: int) -> bool
    return x >= 0 and
           y >= 0 and
           x < world.map_width(target) and
           y < world.map_height(target)
end

public func bool_or(values: map<int, bool>, id: int, fallback: bool) -> bool
    const maybe: optional<bool> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func float_or(values: map<int, float>, id: int, fallback: float) -> float
    const maybe: optional<float> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func int_or(values: map<int, int>, id: int, fallback: int) -> int
    const maybe: optional<int> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func bool_text_or(values: map<text, bool>, key: text, fallback: bool) -> bool
    const maybe: optional<bool> = values.get(key)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func int_text_or(values: map<text, int>, key: text, fallback: int) -> int
    const maybe: optional<int> = values.get(key)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end
