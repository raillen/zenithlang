namespace borealis.game.controllers

public enum Direction
    None
    Left
    Right
    Up
    Down
end

public struct TopDownConfig
    speed: float = 120.0
end

public struct PlatformConfig
    speed: float = 120.0
    gravity: float = 700.0
    jump_force: float = 260.0
end

public struct Controller
    kind: text
    enabled: bool
    body: contracts.Body2D
    facing: controllers.Direction
    sprite_id: text
    sprite_state: text
    flip_x: bool
    grounded: bool
end

public func direction_from_input(up: bool, down: bool, left: bool, right: bool) -> controllers.Direction
    if left
        return controllers.Direction.Left
    end
    if right
        return controllers.Direction.Right
    end
    if up
        return controllers.Direction.Up
    end
    if down
        return controllers.Direction.Down
    end
    return controllers.Direction.None
end

public func direction_is_left(direction: controllers.Direction) -> bool
    match direction
        case controllers.Direction.Left ->
            return true
        case controllers.Direction.Right ->
            return false
        case controllers.Direction.Up ->
            return false
        case controllers.Direction.Down ->
            return false
        case controllers.Direction.None ->
            return false
    end
end

public func direction_is_right(direction: controllers.Direction) -> bool
    match direction
        case controllers.Direction.Left ->
            return false
        case controllers.Direction.Right ->
            return true
        case controllers.Direction.Up ->
            return false
        case controllers.Direction.Down ->
            return false
        case controllers.Direction.None ->
            return false
    end
end

public func direction_is_up(direction: controllers.Direction) -> bool
    match direction
        case controllers.Direction.Left ->
            return false
        case controllers.Direction.Right ->
            return false
        case controllers.Direction.Up ->
            return true
        case controllers.Direction.Down ->
            return false
        case controllers.Direction.None ->
            return false
    end
end

public func direction_is_down(direction: controllers.Direction) -> bool
    match direction
        case controllers.Direction.Left ->
            return false
        case controllers.Direction.Right ->
            return false
        case controllers.Direction.Up ->
            return false
        case controllers.Direction.Down ->
            return true
        case controllers.Direction.None ->
            return false
    end
end

public func controller_create(
    kind: text = "topdown",
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.Controller(
        kind: kind,
        enabled: true,
        body: body,
        facing: controllers.Direction.Down,
        sprite_id: "",
        sprite_state: "idle",
        flip_x: false,
        grounded: true
    )
end

public func topdown_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("topdown", body)
end

public func four_dir_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("four_dir", body)
end

public func eight_dir_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("eight_dir", body)
end

public func grid_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("grid", body)
end

public func twin_stick_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("twin_stick", body)
end

public func flight_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("flight", body)
end

public func rail_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("rail", body)
end

public func platform_create(
    body: contracts.Body2D = contracts.body2d()
) -> controllers.Controller
    return controllers.controller_create("platform", body)
end

public func controller_set_enabled(
    controller: controllers.Controller,
    enabled: bool
) -> controllers.Controller
    var next: controllers.Controller = controller
    next.enabled = enabled
    return next
end

public func controller_reset(controller: controllers.Controller) -> controllers.Controller
    var next: controllers.Controller = controller
    next.body = contracts.body2d(position: controller.body.position)
    next.facing = controllers.Direction.Down
    next.sprite_state = "idle"
    next.flip_x = false
    next.grounded = true
    return next
end

public func controller_bind_sprite(
    controller: controllers.Controller,
    sprite_id: text
) -> controllers.Controller
    var next: controllers.Controller = controller
    next.sprite_id = sprite_id
    return next
end

public func controller_unbind_sprite(controller: controllers.Controller) -> controllers.Controller
    var next: controllers.Controller = controller
    next.sprite_id = ""
    return next
end

public func controller_body(controller: controllers.Controller) -> contracts.Body2D
    return controller.body
end

public func controller_visual_state(controller: controllers.Controller) -> text
    return controller.sprite_state
end

public func topdown_update(
    position: game.Vector2,
    up: bool,
    down: bool,
    left: bool,
    right: bool,
    config: controllers.TopDownConfig = controllers.TopDownConfig(),
    dt: float = 1.0 / 60.0
) -> game.Vector2
    var vx: float = 0.0
    var vy: float = 0.0

    if left
        vx = vx - config.speed
    end
    if right
        vx = vx + config.speed
    end
    if up
        vy = vy - config.speed
    end
    if down
        vy = vy + config.speed
    end

    return game.vec2(position.x + (vx * dt), position.y + (vy * dt))
end

public func grid_step(position: game.Vector2, direction: controllers.Direction, cell_size: float = 32.0) -> game.Vector2
    match direction
        case controllers.Direction.Left ->
            return game.vec2(position.x - cell_size, position.y)
        case controllers.Direction.Right ->
            return game.vec2(position.x + cell_size, position.y)
        case controllers.Direction.Up ->
            return game.vec2(position.x, position.y - cell_size)
        case controllers.Direction.Down ->
            return game.vec2(position.x, position.y + cell_size)
        case controllers.Direction.None ->
            return position
    end
end

public func topdown_velocity(
    actions: contracts.ActionInput,
    config: controllers.TopDownConfig = controllers.TopDownConfig()
) -> game.Vector2
    const axis: game.Vector2 = contracts.action_axis(actions)
    return game.vec2(axis.x * config.speed, axis.y * config.speed)
end

public func topdown_body_update(
    body: contracts.Body2D,
    actions: contracts.ActionInput,
    config: controllers.TopDownConfig = controllers.TopDownConfig(),
    dt: float = 1.0 / 60.0
) -> contracts.Body2D
    const velocity: game.Vector2 = controllers.topdown_velocity(actions, config)
    const with_velocity: contracts.Body2D = contracts.body_set_velocity(body, velocity)
    return movement.body_step(with_velocity, dt)
end

public func grid_body_update(
    body: contracts.Body2D,
    actions: contracts.ActionInput,
    cell_size: float = 32.0
) -> contracts.Body2D
    const direction: controllers.Direction = controllers.direction_from_input(
        actions.up,
        actions.down,
        actions.left,
        actions.right
    )
    return contracts.body_set_position(body, controllers.grid_step(body.position, direction, cell_size))
end

public func platform_body_update(
    body: contracts.Body2D,
    actions: contracts.ActionInput,
    grounded: bool,
    config: controllers.PlatformConfig = controllers.PlatformConfig(),
    dt: float = 1.0 / 60.0
) -> controllers.Controller
    var velocity: game.Vector2 = body.velocity
    velocity.x = 0.0

    if actions.left
        velocity.x = velocity.x - config.speed
    end
    if actions.right
        velocity.x = velocity.x + config.speed
    end

    velocity.y = velocity.y + (config.gravity * dt)
    var next_grounded: bool = grounded
    if grounded and actions.jump
        velocity.y = 0.0 - config.jump_force
        next_grounded = false
    end

    var next_body: contracts.Body2D = contracts.body_set_velocity(body, velocity)
    next_body = contracts.body_integrate(next_body, dt)

    if next_body.position.y >= 0.0
        next_body = contracts.Body2D(
            position: game.vec2(next_body.position.x, 0.0),
            velocity: game.vec2(next_body.velocity.x, 0.0)
        )
        next_grounded = true
    end

    return controllers.Controller(
        kind: "platform",
        enabled: true,
        body: next_body,
        facing: controllers.direction_from_input(false, false, actions.left, actions.right),
        sprite_id: "",
        sprite_state: "idle",
        flip_x: false,
        grounded: next_grounded
    )
end

public func controller_update(
    controller: controllers.Controller,
    actions: contracts.ActionInput,
    dt: float = 1.0 / 60.0
) -> controllers.Controller
    if controller.enabled == false
        return controller
    end

    var next: controllers.Controller = controller
    next.facing = controllers.direction_from_input(actions.up, actions.down, actions.left, actions.right)

    if controller.kind == "grid"
        next.body = controllers.grid_body_update(controller.body, actions)
        next.body = contracts.body_set_velocity(next.body, game.vec2(0.0, 0.0))
        return controllers.controller_sync_sprite(next)
    end

    if controller.kind == "platform"
        const stepped: controllers.Controller = controllers.platform_body_update(
            controller.body,
            actions,
            controller.grounded,
            dt: dt
        )
        next.body = stepped.body
        next.grounded = stepped.grounded
        return controllers.controller_sync_sprite(next)
    end

    if controller.kind == "four_dir"
        const single_axis: contracts.ActionInput = contracts.ActionInput(
            up: controllers.direction_is_up(next.facing),
            down: controllers.direction_is_down(next.facing),
            left: controllers.direction_is_left(next.facing),
            right: controllers.direction_is_right(next.facing),
            jump: actions.jump,
            dash: actions.dash,
            primary: actions.primary,
            secondary: actions.secondary
        )
        next.body = controllers.topdown_body_update(controller.body, single_axis, dt: dt)
        return controllers.controller_sync_sprite(next)
    end

    next.body = controllers.topdown_body_update(controller.body, actions, dt: dt)
    return controllers.controller_sync_sprite(next)
end

public func controller_sync_sprite(controller: controllers.Controller) -> controllers.Controller
    var next: controllers.Controller = controller
    const speed: float = contracts.body_speed(controller.body)

    next.sprite_state = "idle"
    if controller.grounded == false
        next.sprite_state = "fall"
        if controller.body.velocity.y < 0.0
            next.sprite_state = "jump"
        end
    end
    if controller.grounded and speed > 0.01
        next.sprite_state = "move"
    end

    next.flip_x = controllers.direction_is_left(controller.facing)
    return next
end
