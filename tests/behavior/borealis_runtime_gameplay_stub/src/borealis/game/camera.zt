namespace borealis.game.camera

public struct CameraState
    center: game.Vector2
    zoom: float = 1.0
end

public struct CameraBounds
    min_x: float
    min_y: float
    max_x: float
    max_y: float
end

public struct CameraDeadzone
    width: float = 0.0
    height: float = 0.0
end

public struct CameraRig
    state: camera.CameraState
    offset: game.Vector2
    shake_offset: game.Vector2
    look_ahead: game.Vector2
    deadzone: camera.CameraDeadzone
    bounds: camera.CameraBounds
    bounds_enabled: bool = false
    shake_intensity: float = 0.0
    shake_timer: float = 0.0
end

public struct CameraFraming
    center: game.Vector2
    zoom: float = 1.0
end

public func create(center: game.Vector2 = game.vec2(0.0, 0.0), zoom: float = 1.0) -> camera.CameraState
    return camera.CameraState(center: center, zoom: zoom)
end

public func camera_deadzone(width: float = 0.0, height: float = 0.0) -> camera.CameraDeadzone
    return camera.CameraDeadzone(width: width, height: height)
end

public func camera_rig_create(center: game.Vector2 = game.vec2(0.0, 0.0), zoom: float = 1.0) -> camera.CameraRig
    return camera.CameraRig(
        state: camera.create(center, zoom),
        offset: game.vec2(0.0, 0.0),
        shake_offset: game.vec2(0.0, 0.0),
        look_ahead: game.vec2(0.0, 0.0),
        deadzone: camera.camera_deadzone(),
        bounds: camera.CameraBounds(min_x: 0.0, min_y: 0.0, max_x: 0.0, max_y: 0.0),
        bounds_enabled: false,
        shake_intensity: 0.0,
        shake_timer: 0.0
    )
end

public func camera_set_position(state: camera.CameraState, position: game.Vector2) -> camera.CameraState
    return camera.CameraState(center: position, zoom: state.zoom)
end

public func camera_set_zoom(state: camera.CameraState, value: float) -> camera.CameraState
    var next: camera.CameraState = state
    next.zoom = value
    if next.zoom <= 0.01
        next.zoom = 0.01
    end
    return next
end

public func world_to_screen(
    state: camera.CameraState,
    position: game.Vector2,
    viewport_center: game.Vector2 = game.vec2(0.0, 0.0)
) -> game.Vector2
    return game.vec2(
        ((position.x - state.center.x) * state.zoom) + viewport_center.x,
        ((position.y - state.center.y) * state.zoom) + viewport_center.y
    )
end

public func screen_to_world(
    state: camera.CameraState,
    position: game.Vector2,
    viewport_center: game.Vector2 = game.vec2(0.0, 0.0)
) -> game.Vector2
    return game.vec2(
        ((position.x - viewport_center.x) / state.zoom) + state.center.x,
        ((position.y - viewport_center.y) / state.zoom) + state.center.y
    )
end

public func follow(current: game.Vector2, target: game.Vector2, smooth: float = 0.15) -> game.Vector2
    const next_x: float = current.x + ((target.x - current.x) * smooth)
    const next_y: float = current.y + ((target.y - current.y) * smooth)
    return game.vec2(next_x, next_y)
end

public func camera_lerp_to(state: camera.CameraState, target: game.Vector2, speed: float = 0.15) -> camera.CameraState
    return camera.CameraState(
        center: camera.follow(state.center, target, speed),
        zoom: state.zoom
    )
end

public func camera_center_on(target: game.Vector2, zoom: float = 1.0) -> camera.CameraState
    return camera.CameraState(center: target, zoom: zoom)
end

public func apply_bounds(center: game.Vector2, bounds: camera.CameraBounds) -> game.Vector2
    var next_x: float = center.x
    var next_y: float = center.y

    if next_x < bounds.min_x
        next_x = bounds.min_x
    end
    if next_x > bounds.max_x
        next_x = bounds.max_x
    end

    if next_y < bounds.min_y
        next_y = bounds.min_y
    end
    if next_y > bounds.max_y
        next_y = bounds.max_y
    end

    return game.vec2(next_x, next_y)
end

public func shake_offset(intensity: float, tick: int) -> game.Vector2
    if (tick % 2) == 0
        return game.vec2(intensity, -intensity)
    end
    return game.vec2(-intensity, intensity)
end

public func follow_body(current: game.Vector2, body: contracts.Body2D, smooth: float = 0.15) -> game.Vector2
    return camera.follow(current, body.position, smooth)
end

public func camera_set_bounds(rig: camera.CameraRig, bounds: camera.CameraBounds) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.bounds = bounds
    next.bounds_enabled = true
    next.state.center = camera.apply_bounds(next.state.center, bounds)
    return next
end

public func camera_set_offset(rig: camera.CameraRig, offset: game.Vector2) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.offset = offset
    return next
end

public func camera_set_deadzone(rig: camera.CameraRig, deadzone: camera.CameraDeadzone) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.deadzone = deadzone
    return next
end

public func camera_set_look_ahead(rig: camera.CameraRig, offset: game.Vector2) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.look_ahead = offset
    return next
end

public func camera_lock_to(rig: camera.CameraRig, target: game.Vector2) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.state.center = target
    if next.bounds_enabled
        next.state.center = camera.apply_bounds(next.state.center, next.bounds)
    end
    return next
end

public func camera_follow_rig(
    rig: camera.CameraRig,
    target: game.Vector2,
    smooth: float = 0.15
) -> camera.CameraRig
    var next: camera.CameraRig = rig
    var follow_target: game.Vector2 = game.vec2(
        target.x + rig.look_ahead.x,
        target.y + rig.look_ahead.y
    )

    if rig.deadzone.width > 0.0
        const half_width: float = rig.deadzone.width * 0.5
        if follow_target.x > (rig.state.center.x + half_width)
            follow_target.x = follow_target.x - half_width
        end
        if follow_target.x < (rig.state.center.x - half_width)
            follow_target.x = follow_target.x + half_width
        end
        if follow_target.x >= (rig.state.center.x - half_width) and follow_target.x <= (rig.state.center.x + half_width)
            follow_target.x = rig.state.center.x
        end
    end

    if rig.deadzone.height > 0.0
        const half_height: float = rig.deadzone.height * 0.5
        if follow_target.y > (rig.state.center.y + half_height)
            follow_target.y = follow_target.y - half_height
        end
        if follow_target.y < (rig.state.center.y - half_height)
            follow_target.y = follow_target.y + half_height
        end
        if follow_target.y >= (rig.state.center.y - half_height) and follow_target.y <= (rig.state.center.y + half_height)
            follow_target.y = rig.state.center.y
        end
    end

    next.state.center = camera.follow(rig.state.center, follow_target, smooth)
    if next.bounds_enabled
        next.state.center = camera.apply_bounds(next.state.center, next.bounds)
    end
    return next
end

public func camera_shake(rig: camera.CameraRig, intensity: float, duration: float) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.shake_intensity = intensity
    next.shake_timer = duration
    return next
end

public func camera_step(rig: camera.CameraRig, tick: int, dt: float = 1.0 / 60.0) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.shake_offset = game.vec2(0.0, 0.0)

    if next.shake_timer > 0.0
        next.shake_timer = next.shake_timer - dt
        if next.shake_timer < 0.0
            next.shake_timer = 0.0
        end
        next.shake_offset = camera.shake_offset(next.shake_intensity, tick)
    else
        next.shake_intensity = 0.0
    end

    return next
end

public func camera_resolve_center(rig: camera.CameraRig) -> game.Vector2
    var resolved: game.Vector2 = game.vec2(
        rig.state.center.x + rig.offset.x + rig.shake_offset.x,
        rig.state.center.y + rig.offset.y + rig.shake_offset.y
    )
    if rig.bounds_enabled
        resolved = camera.apply_bounds(resolved, rig.bounds)
    end
    return resolved
end

public func camera_frame_targets(
    first: game.Vector2,
    second: game.Vector2,
    padding: float = 32.0
) -> camera.CameraFraming
    var min_x: float = first.x
    var max_x: float = first.x
    var min_y: float = first.y
    var max_y: float = first.y

    if second.x < min_x
        min_x = second.x
    end
    if second.x > max_x
        max_x = second.x
    end
    if second.y < min_y
        min_y = second.y
    end
    if second.y > max_y
        max_y = second.y
    end

    const width: float = (max_x - min_x) + (padding * 2.0)
    const height: float = (max_y - min_y) + (padding * 2.0)

    var zoom: float = 1.0
    if width > 0.0 or height > 0.0
        const dominant: float = width + height
        zoom = 600.0 / (600.0 + dominant)
    end
    if zoom < 0.2
        zoom = 0.2
    end

    return camera.CameraFraming(
        center: game.vec2((min_x + max_x) * 0.5, (min_y + max_y) * 0.5),
        zoom: zoom
    )
end

public func camera_apply_framing(rig: camera.CameraRig, framing: camera.CameraFraming) -> camera.CameraRig
    var next: camera.CameraRig = rig
    next.state.center = framing.center
    next.state.zoom = framing.zoom
    if next.bounds_enabled
        next.state.center = camera.apply_bounds(next.state.center, next.bounds)
    end
    return next
end
