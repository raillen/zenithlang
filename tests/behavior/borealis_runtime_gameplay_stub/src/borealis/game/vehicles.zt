namespace borealis.game.vehicles

extern c
    func zt_math_sin(value: float) -> float
    func zt_math_cos(value: float) -> float
end

public struct CarConfig
    accel: float = 220.0
    brake: float = 260.0
    max_speed: float = 300.0
    steering_speed: float = 3.0
    traction: float = 1.0
    grip: float = 1.0
    drag: float = 80.0
end

public struct CarState
    speed: float = 0.0
    steering: float = 0.0
    heading: float = 0.0
    traction: float = 1.0
    grip: float = 1.0
    handbrake: bool = false
    boost_timer: float = 0.0
    boost_amount: float = 0.0
    x: float = 0.0
    y: float = 0.0
end

public func car_create(config: vehicles.CarConfig = vehicles.CarConfig()) -> vehicles.CarState
    return vehicles.CarState(
        traction: config.traction,
        grip: config.grip
    )
end

public func car_steer(state: vehicles.CarState, direction: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.steering = direction
    return next
end

public func car_accelerate(state: vehicles.CarState, amount: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.speed = next.speed + amount
    return next
end

public func car_brake(state: vehicles.CarState, amount: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.speed = next.speed - amount
    return next
end

public func car_handbrake(state: vehicles.CarState, enabled: bool) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.handbrake = enabled
    return next
end

public func car_boost(state: vehicles.CarState, amount: float, duration: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.boost_amount = amount
    next.boost_timer = duration
    return next
end

public func car_set_traction(state: vehicles.CarState, value: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.traction = value
    return next
end

public func car_set_grip(state: vehicles.CarState, value: float) -> vehicles.CarState
    var next: vehicles.CarState = state
    next.grip = value
    return next
end

public func car_position(state: vehicles.CarState) -> game.Vector2
    return game.vec2(state.x, state.y)
end

public func car_forward(state: vehicles.CarState) -> game.Vector2
    return game.vec2(vehicles.zt_math_cos(state.heading), vehicles.zt_math_sin(state.heading))
end

public func car_update(
    state: vehicles.CarState,
    throttle: float,
    brake: float,
    steer: float,
    config: vehicles.CarConfig = vehicles.CarConfig(),
    dt: float = 1.0 / 60.0
) -> vehicles.CarState
    var next: vehicles.CarState = state
    var max_speed: float = config.max_speed

    if next.boost_timer > 0.0
        next.boost_timer = next.boost_timer - dt
        max_speed = max_speed + next.boost_amount
    else
        next.boost_amount = 0.0
        next.boost_timer = 0.0
    end

    next.speed = next.speed + ((throttle * config.accel * next.traction) - (brake * config.brake)) * dt

    if throttle == 0.0 and brake == 0.0
        var drag_scale: float = 1.0
        if next.handbrake
            drag_scale = 2.0
        end
        const drag_force: float = config.drag * dt * drag_scale
        if next.speed > 0.0
            next.speed = next.speed - drag_force
            if next.speed < 0.0
                next.speed = 0.0
            end
        end
        if next.speed < 0.0
            next.speed = next.speed + drag_force
            if next.speed > 0.0
                next.speed = 0.0
            end
        end
    end

    if next.speed > max_speed
        next.speed = max_speed
    end
    if next.speed < (0.0 - max_speed)
        next.speed = 0.0 - max_speed
    end

    next.steering = steer
    next.heading = next.heading + (steer * config.steering_speed * next.grip * dt)

    const forward: game.Vector2 = vehicles.car_forward(next)
    next.x = next.x + (forward.x * next.speed * dt)
    next.y = next.y + (forward.y * next.speed * dt)
    return next
end
