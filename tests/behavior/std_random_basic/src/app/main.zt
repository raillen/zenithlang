namespace app.main

import std.random as random

func main() -> result<void, text>
    random.seed(12345)
    if random.seeded == false
        return error("std.random.seed should set seeded=true")
    end
    if random.last_seed != 12345
        return error("std.random.seed should store last_seed")
    end
    if random.draw_count != 0
        return error("std.random.seed should reset draw_count")
    end

    const first_a: int = random.next()
    const first_b: int = random.next()
    if random.draw_count != 2
        return error("std.random.next should increment draw_count")
    end

    random.seed(12345)
    if random.draw_count != 0
        return error("std.random.seed should reset draw_count after reseed")
    end

    const second_a: int = random.next()
    const second_b: int = random.next()

    if first_a != second_a or first_b != second_b
        return error("std.random.seed should make sequence deterministic")
    end

    const ranged: int = random.between(10, 20)?
    if ranged < 10 or ranged > 20
        return error("std.random.between should stay inside inclusive range")
    end
    if random.draw_count != 3
        return error("std.random.between should consume one draw in non-degenerate range")
    end

    return success()
end
