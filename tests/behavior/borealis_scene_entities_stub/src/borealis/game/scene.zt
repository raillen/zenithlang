namespace borealis.game.scene

public struct Scene
    id: int
end

public var scene_next_id: int = 1
public var scene_alive: map<int, bool> = {}
public var scene_name: map<int, text> = {}
public var scene_enter_count: map<int, int> = {}
public var scene_exit_count: map<int, int> = {}
public var scene_update_count: map<int, int> = {}
public var scene_draw_count: map<int, int> = {}
public var scene_last_dt: map<int, float> = {}
public var scene_current_id: int = 0
public var scene_entity_owner: map<int, int> = {}
public var scene_phase: map<int, text> = {}
public var scene_document_id: map<int, text> = {}
public var scene_stack: map<int, int> = {}
public var scene_stack_depth: int = 0

public func scene_bool_or(values: map<int, bool>, id: int, fallback: bool) -> bool
    const value: optional<bool> = values.get(id)
    match value
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func scene_text_or(values: map<int, text>, id: int, fallback: text) -> text
    const value: optional<text> = values.get(id)
    match value
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func scene_int_or(values: map<int, int>, id: int, fallback: int) -> int
    const value: optional<int> = values.get(id)
    match value
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func scene_float_or(values: map<int, float>, id: int, fallback: float) -> float
    const value: optional<float> = values.get(id)
    match value
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func scene_bool_set(values: map<int, bool>, id: int, value: bool) -> map<int, bool>
    var next_values: map<int, bool> = values
    next_values[id] = value
    return next_values
end

public func scene_text_set(values: map<int, text>, id: int, value: text) -> map<int, text>
    var next_values: map<int, text> = values
    next_values[id] = value
    return next_values
end

public func scene_int_set(values: map<int, int>, id: int, value: int) -> map<int, int>
    var next_values: map<int, int> = values
    next_values[id] = value
    return next_values
end

public func scene_float_set(values: map<int, float>, id: int, value: float) -> map<int, float>
    var next_values: map<int, float> = values
    next_values[id] = value
    return next_values
end

public func scene_require_exists(target: scene.Scene) -> result<void, core.Error>
    if scene.scene_exists(target) == false
        return error("scene: scene not found")
    end
    return success()
end

public func scene_create(name: text) -> result<scene.Scene, core.Error>
    const new_id: int = scene_next_id
    scene_next_id = scene_next_id + 1

    scene_alive = scene.scene_bool_set(scene_alive, new_id, true)
    scene_name = scene.scene_text_set(scene_name, new_id, name)
    scene_enter_count = scene.scene_int_set(scene_enter_count, new_id, 0)
    scene_exit_count = scene.scene_int_set(scene_exit_count, new_id, 0)
    scene_update_count = scene.scene_int_set(scene_update_count, new_id, 0)
    scene_draw_count = scene.scene_int_set(scene_draw_count, new_id, 0)
    scene_last_dt = scene.scene_float_set(scene_last_dt, new_id, 0.0)
    scene_phase = scene.scene_text_set(scene_phase, new_id, "ready")
    scene_document_id = scene.scene_text_set(scene_document_id, new_id, name)

    return success(scene.Scene(id: new_id))
end

public func scene_destroy(target: scene.Scene) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_alive = scene.scene_bool_set(scene_alive, target.id, false)
    if scene_current_id == target.id
        scene_current_id = 0
    end
    return success()
end

public func scene_exists(target: scene.Scene) -> bool
    return scene.scene_bool_or(scene_alive, target.id, false)
end

public func scene_set_name(target: scene.Scene, name: text) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_name = scene.scene_text_set(scene_name, target.id, name)
    return success()
end

public func scene_get_name(target: scene.Scene) -> text
    return scene.scene_text_or(scene_name, target.id, "")
end

public func scene_set_phase(target: scene.Scene, phase: text) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_phase = scene.scene_text_set(scene_phase, target.id, phase)
    return success()
end

public func scene_get_phase(target: scene.Scene) -> text
    return scene.scene_text_or(scene_phase, target.id, "")
end

public func scene_set_document_id(target: scene.Scene, document_id: text) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    if document_id == ""
        return error("scene: document id cannot be empty")
    end
    scene_document_id = scene.scene_text_set(scene_document_id, target.id, document_id)
    return success()
end

public func scene_get_document_id(target: scene.Scene) -> text
    return scene.scene_text_or(scene_document_id, target.id, "")
end

public func scene_count() -> int
    var total: int = 0
    var probe: int = 1
    while probe < scene_next_id
        if scene.scene_bool_or(scene_alive, probe, false)
            total = total + 1
        end
        probe = probe + 1
    end
    return total
end

public func scene_at(index: int) -> optional<scene.Scene>
    if index < 0
        return none
    end

    var probe: int = 1
    var cursor: int = 0
    while probe < scene_next_id
        if scene.scene_bool_or(scene_alive, probe, false)
            if cursor == index
                return scene.Scene(id: probe)
            end
            cursor = cursor + 1
        end
        probe = probe + 1
    end
    return none
end

public func scene_find(name: text) -> optional<scene.Scene>
    var probe: int = 1
    while probe < scene_next_id
        if scene.scene_bool_or(scene_alive, probe, false)
            if scene.scene_text_or(scene_name, probe, "") == name
                return scene.Scene(id: probe)
            end
        end
        probe = probe + 1
    end
    return none
end

public func scene_enter(target: scene.Scene) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_current_id = target.id
    scene_enter_count = scene.scene_int_set(scene_enter_count, target.id, scene.scene_int_or(scene_enter_count, target.id, 0) + 1)
    return success()
end

public func scene_exit(target: scene.Scene) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    if scene_current_id == target.id
        scene_current_id = 0
    end
    scene_exit_count = scene.scene_int_set(scene_exit_count, target.id, scene.scene_int_or(scene_exit_count, target.id, 0) + 1)
    return success()
end

public func scene_transition(from_scene: scene.Scene, to_scene: scene.Scene) -> result<void, core.Error>
    scene.scene_exit(from_scene)?
    scene.scene_enter(to_scene)?
    return success()
end

public func scene_push(target: scene.Scene) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_stack = scene.scene_int_set(scene_stack, scene_stack_depth, target.id)
    scene_stack_depth = scene_stack_depth + 1
    scene.scene_enter(target)?
    return success()
end

public func scene_pop() -> result<void, core.Error>
    if scene_stack_depth <= 0
        return error("scene: stack is empty")
    end

    scene_stack_depth = scene_stack_depth - 1
    scene_stack = scene.scene_int_set(scene_stack, scene_stack_depth, 0)

    if scene_stack_depth <= 0
        scene_current_id = 0
        return success()
    end

    scene_current_id = scene.scene_int_or(scene_stack, scene_stack_depth - 1, 0)
    return success()
end

public func scene_stack_count() -> int
    return scene_stack_depth
end

public func scene_stack_at(index: int) -> optional<scene.Scene>
    if index < 0
        return none
    end
    if index >= scene_stack_depth
        return none
    end

    const scene_id: int = scene.scene_int_or(scene_stack, index, 0)
    if scene_id <= 0
        return none
    end
    return scene.Scene(id: scene_id)
end

public func scene_stack_top() -> optional<scene.Scene>
    if scene_stack_depth <= 0
        return none
    end
    return scene.scene_stack_at(scene_stack_depth - 1)
end

public func scene_active() -> optional<scene.Scene>
    if scene_current_id <= 0
        return none
    end
    return scene.Scene(id: scene_current_id)
end

public func scene_add_entity(target: scene.Scene, entity: entities.Entity) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    if entities.entity_exists(entity) == false
        return error("scene: entity not found")
    end
    scene_entity_owner = scene.scene_int_set(scene_entity_owner, entity.id, target.id)
    return success()
end

public func scene_remove_entity(target: scene.Scene, entity: entities.Entity) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    if entities.entity_exists(entity) == false
        return error("scene: entity not found")
    end
    if scene.scene_int_or(scene_entity_owner, entity.id, 0) == target.id
        scene_entity_owner = scene.scene_int_set(scene_entity_owner, entity.id, 0)
    end
    return success()
end

public func scene_entity_count(target: scene.Scene) -> int
    if scene.scene_exists(target) == false
        return 0
    end

    const total_entities: int = entities.entity_count()
    var index: int = 0
    var total: int = 0
    while index < total_entities
        const maybe_entity: optional<entities.Entity> = entities.entity_at(index)
        match maybe_entity
            case value current ->
                if scene.scene_int_or(scene_entity_owner, current.id, 0) == target.id
                    total = total + 1
                end
            case none ->
        end
        index = index + 1
    end
    return total
end

public func scene_entity_at(target: scene.Scene, index: int) -> optional<entities.Entity>
    if scene.scene_exists(target) == false
        return none
    end
    if index < 0
        return none
    end

    const total_entities: int = entities.entity_count()
    var probe: int = 0
    var cursor: int = 0
    while probe < total_entities
        const maybe_entity: optional<entities.Entity> = entities.entity_at(probe)
        match maybe_entity
            case value current ->
                if scene.scene_int_or(scene_entity_owner, current.id, 0) == target.id
                    if cursor == index
                        return current
                    end
                    cursor = cursor + 1
                end
            case none ->
        end
        probe = probe + 1
    end
    return none
end

public func scene_update(target: scene.Scene, dt: float) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_update_count = scene.scene_int_set(scene_update_count, target.id, scene.scene_int_or(scene_update_count, target.id, 0) + 1)
    scene_last_dt = scene.scene_float_set(scene_last_dt, target.id, dt)
    return success()
end

public func scene_draw(target: scene.Scene) -> result<void, core.Error>
    scene.scene_require_exists(target)?
    scene_draw_count = scene.scene_int_set(scene_draw_count, target.id, scene.scene_int_or(scene_draw_count, target.id, 0) + 1)
    return success()
end

public func scene_update_ticks(target: scene.Scene) -> int
    return scene.scene_int_or(scene_update_count, target.id, 0)
end

public func scene_draw_ticks(target: scene.Scene) -> int
    return scene.scene_int_or(scene_draw_count, target.id, 0)
end

public func scene_last_delta(target: scene.Scene) -> float
    return scene.scene_float_or(scene_last_dt, target.id, 0.0)
end






