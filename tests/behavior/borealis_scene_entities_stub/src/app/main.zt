namespace app.main

import borealis.game.entities as entities
import borealis.game.scene as scene

func expect(value: bool, message: text) -> result<void, core.Error>
    if value == false
        return error(message)
    end
    return success()
end

func main() -> result<void, core.Error>
    const tag_player: text = "player"
    const tag_enemy: text = "enemy"
    const gameplay: scene.Scene = scene.scene_create("gameplay")?
    const pause_menu: scene.Scene = scene.scene_create("pause")?
    const player: entities.Entity = entities.entity_create("player")?
    const enemy: entities.Entity = entities.entity_create("enemy")?

    scene.scene_set_document_id(gameplay, "scene.gameplay")?
    scene.scene_set_phase(gameplay, "playing")?
    expect(scene.scene_get_document_id(gameplay) == "scene.gameplay", "scene document id should be stable")?
    expect(scene.scene_get_phase(gameplay) == "playing", "scene phase should be tracked")?

    entities.entity_set_parent(enemy, player)?
    entities.entity_add_tag(player, tag_player)?
    entities.entity_add_tag(enemy, tag_enemy)?

    expect(entities.entity_child_count(player) == 1, "player should have one child")?
    expect(entities.entity_has_tag(player, tag_player), "player tag should exist")?
    expect(entities.entity_has_tag(enemy, tag_enemy), "enemy tag should exist")?

    scene.scene_add_entity(gameplay, player)?
    scene.scene_add_entity(gameplay, enemy)?
    expect(scene.scene_entity_count(gameplay) == 2, "scene should have two entities")?

    scene.scene_enter(gameplay)?

    const maybe_active: optional<scene.Scene> = scene.scene_active()
    match maybe_active
        case value active_scene ->
            expect(active_scene.id == gameplay.id, "scene should be active")?
        case none ->
            return error("scene should be active")
    end

    scene.scene_update(gameplay, 1.0 / 60.0)?
    scene.scene_draw(gameplay)?
    expect(scene.scene_update_ticks(gameplay) == 1, "scene update ticks should be one")?
    expect(scene.scene_draw_ticks(gameplay) == 1, "scene draw ticks should be one")?

    scene.scene_push(gameplay)?
    scene.scene_push(pause_menu)?
    expect(scene.scene_stack_count() == 2, "scene stack should track pushed scenes")?

    const maybe_top: optional<scene.Scene> = scene.scene_stack_top()
    match maybe_top
        case value top_scene ->
            expect(top_scene.id == pause_menu.id, "scene stack top should be pause scene")?
        case none ->
            return error("scene stack top should exist")
    end

    scene.scene_pop()?
    expect(scene.scene_stack_count() == 1, "scene pop should reduce stack depth")?

    const maybe_after_pop: optional<scene.Scene> = scene.scene_active()
    match maybe_after_pop
        case value active_after_pop ->
            expect(active_after_pop.id == gameplay.id, "scene pop should restore gameplay as active")?
        case none ->
            return error("scene pop should keep gameplay active")
    end

    scene.scene_pop()?
    expect(scene.scene_stack_count() == 0, "scene stack should become empty")?

    const empty_pop: result<void, core.Error> = scene.scene_pop()
    match empty_pop
        case success() ->
            return error("scene pop should reject an empty stack")
        case error(err) ->
            expect(err.message != "", "empty stack error should be clear")?
    end

    entities.entity_destroy(enemy)?
    entities.entity_destroy(player)?
    scene.scene_destroy(pause_menu)?
    scene.scene_destroy(gameplay)?
    return success()
end
