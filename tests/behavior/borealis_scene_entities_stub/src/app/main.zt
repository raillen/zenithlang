namespace app.main

import borealis.game.entities as entities
import borealis.game.scene as scene

func expect(value: bool, message: text) -> result<void, core.Error>
    if value == false
        return error(message)
    end
    return success()
end

func main() -> result<void, core.Error>
    const tag_player: text = "player"
    const tag_enemy: text = "enemy"
    const gameplay: scene.Scene = scene.scene_create("gameplay")?
    const player: entities.Entity = entities.entity_create("player")?
    const enemy: entities.Entity = entities.entity_create("enemy")?

    entities.entity_set_parent(enemy, player)?
    entities.entity_add_tag(player, tag_player)?
    entities.entity_add_tag(enemy, tag_enemy)?

    expect(entities.entity_child_count(player) == 1, "player should have one child")?
    expect(entities.entity_has_tag(player, tag_player), "player tag should exist")?
    expect(entities.entity_has_tag(enemy, tag_enemy), "enemy tag should exist")?

    scene.scene_add_entity(gameplay, player)?
    scene.scene_add_entity(gameplay, enemy)?
    expect(scene.scene_entity_count(gameplay) == 2, "scene should have two entities")?

    scene.scene_enter(gameplay)?

    const maybe_active: optional<scene.Scene> = scene.scene_active()
    match maybe_active
        case value active_scene ->
            expect(active_scene.id == gameplay.id, "scene should be active")?
        case none ->
            return error("scene should be active")
    end

    scene.scene_update(gameplay, 1.0 / 60.0)?
    scene.scene_draw(gameplay)?
    expect(scene.scene_update_ticks(gameplay) == 1, "scene update ticks should be one")?
    expect(scene.scene_draw_ticks(gameplay) == 1, "scene draw ticks should be one")?

    entities.entity_destroy(enemy)?
    entities.entity_destroy(player)?
    scene.scene_destroy(gameplay)?
    return success()
end
