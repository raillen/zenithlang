namespace app.main

import std.random as random

func main() -> result<void, text>
    random.seed(123)

    if random.draw_count != 0
        return error("std.random.seed should reset draw_count")
    end

    const fixed: int = random.between(5, 5)?
    if fixed != 5
        return error("std.random.between should return exact bound when min == max")
    end
    if random.draw_count != 0
        return error("std.random.between should not draw when min == max")
    end

    const invalid: result<int, text> = random.between(8, 3)

    if random.draw_count != 0
        return error("std.random.between should not draw when returning error")
    end

    return success()
end
