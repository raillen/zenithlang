namespace borealis.raylib

extern c
    func zt_borealis_open_window(title: text, width: int, height: int, target_fps: int, backend_id: int) -> result<int, core.Error>
    func zt_borealis_close_window(window_id: int) -> result<void, core.Error>
    func zt_borealis_window_should_close(window_id: int) -> bool
    func zt_borealis_begin_frame(window_id: int, clear_r: int, clear_g: int, clear_b: int, clear_a: int) -> result<void, core.Error>
    func zt_borealis_end_frame(window_id: int) -> result<void, core.Error>
    func zt_borealis_draw_rect(window_id: int, x: float, y: float, width: float, height: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_line(window_id: int, x1: float, y1: float, x2: float, y2: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_rect_outline(window_id: int, x: float, y: float, width: float, height: float, thickness: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_circle(window_id: int, x: float, y: float, radius: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_circle_outline(window_id: int, x: float, y: float, radius: float, thickness: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_text(window_id: int, value: text, x: int, y: int, size: int, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_is_key_down(window_id: int, input_code: int) -> bool
    func zt_borealis_is_key_pressed(window_id: int, input_code: int) -> bool
    func zt_borealis_is_key_released(window_id: int, input_code: int) -> bool
    func zt_borealis_raylib_available() -> bool
    func zt_borealis_raylib_loaded_path() -> text
    func zt_borealis_raylib_draw_triangle(window_id: int, x1: float, y1: float, x2: float, y2: float, x3: float, y3: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_raylib_draw_ellipse(window_id: int, x: float, y: float, radius_h: float, radius_v: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_raylib_measure_text(value: text, font_size: int) -> int
    func zt_borealis_raylib_load_texture(path: text) -> result<int, core.Error>
    func zt_borealis_raylib_unload_texture(texture_handle: int) -> result<void, core.Error>
    func zt_borealis_raylib_texture_width(texture_handle: int) -> int
    func zt_borealis_raylib_texture_height(texture_handle: int) -> int
    func zt_borealis_raylib_draw_texture(window_id: int, texture_handle: int, x: float, y: float, tint_r: int, tint_g: int, tint_b: int, tint_a: int) -> result<void, core.Error>
    func zt_borealis_raylib_draw_texture_ex(window_id: int, texture_handle: int, x: float, y: float, rotation: float, scale: float, tint_r: int, tint_g: int, tint_b: int, tint_a: int) -> result<void, core.Error>
    func zt_borealis_raylib_init_audio_device() -> result<void, core.Error>
    func zt_borealis_raylib_close_audio_device() -> result<void, core.Error>
    func zt_borealis_raylib_is_audio_device_ready() -> bool
    func zt_borealis_raylib_set_master_volume(volume: float) -> result<void, core.Error>
