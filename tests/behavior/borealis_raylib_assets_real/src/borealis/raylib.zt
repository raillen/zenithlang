public func rgb(r: int, g: int, b: int) -> raylib.Color
    return raylib.Color(r: r, g: g, b: b, a: 255)
end

public func rgba(r: int, g: int, b: int, a: int) -> raylib.Color
    return raylib.Color(r: r, g: g, b: b, a: a)
end

public func white() -> raylib.Color
    return raylib.rgb(255, 255, 255)
end

public func black() -> raylib.Color
    return raylib.rgb(0, 0, 0)
end

public func red() -> raylib.Color
    return raylib.rgb(230, 41, 55)
end

public func green() -> raylib.Color
    return raylib.rgb(0, 228, 48)
end

public func blue() -> raylib.Color
    return raylib.rgb(0, 121, 241)
end

public func yellow() -> raylib.Color
    return raylib.rgb(253, 249, 0)
end

public func rect(x: float, y: float, width: float, height: float) -> raylib.Rect
    return raylib.Rect(x: x, y: y, width: width, height: height)
end

public func vec2(x: float, y: float) -> raylib.Vector2
    return raylib.Vector2(x: x, y: y)
end

public func key_left() -> int
    return 263
end

public func key_right() -> int
    return 262
end

public func key_up() -> int
    return 265
end

public func key_down() -> int
    return 264
end

public func key_space() -> int
    return 32
end

public func key_escape() -> int
    return 256
end

public func real_assets_smoke(texture_path: text, sound_path: text) -> result<void, core.Error>
    if raylib.available() == false
        return success()
    end

    raylib.require_available()?

    const window: raylib.Window = raylib.open_window_required(
        "borealis-raylib-assets-real",
        640,
        360,
        60
    )?
    const texture: raylib.Texture = raylib.load_texture(texture_path)?

    raylib.expect(texture.id > 0, "load_texture should return a live texture handle")?
    raylib.expect(texture.width == 1 and texture.height == 1, "load_texture should preserve the real PNG dimensions")?
    raylib.expect(raylib.measure_text("raylib assets real", 20) > 0, "measure_text should stay positive with native Raylib")?

    raylib.begin_drawing(window, clear: raylib.rgb(20, 24, 32))?
    raylib.draw_texture(window, texture, raylib.vec2(32.0, 40.0))?
    raylib.draw_texture_ex(
        window,
        texture,
        raylib.vec2(96.0, 48.0),
        rotation: 12.0,
        scale_amount: 12.0,
        tint: raylib.white()
    )?
    raylib.draw_text(window, "real texture ok", 24, 92, 18, raylib.white())?
    raylib.end_drawing(window)?

    raylib.init_audio_device()?
    raylib.expect(raylib.audio_device_ready(), "audio_device_ready should be true after init_audio_device")?
    raylib.set_master_volume(0.2)?

    const sound: raylib.Sound = raylib.load_sound(sound_path)?
    raylib.expect(sound.id > 0, "load_sound should return a live sound handle")?
    raylib.set_sound_volume(sound, 0.25)?
    raylib.play_sound(sound)?
    raylib.stop_sound(sound)?
    raylib.unload_sound(sound)?
    raylib.close_audio_device()?

    raylib.unload_texture(texture)?
    raylib.close_window(window)?
    return success()
end
