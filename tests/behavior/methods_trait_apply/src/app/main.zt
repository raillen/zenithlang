namespace app.main

trait Scoreable
    func score() -> int
end

struct Player
    hp: int
end

apply Player
    mut func heal(amount: int)
        self.hp = self.hp + amount
        return
    end
end

apply Scoreable to Player
    func score() -> int
        return self.hp + 1
    end
end

func main() -> int
    var player: Player = Player(hp: 5)
    player.heal(2)
    return player.score()
end
