    return raylib.zt_borealis_raylib_ease_quad_in_out(t, b, c, d)
end

public func rgb(r: int, g: int, b: int) -> raylib.Color
    return raylib.Color(r: r, g: g, b: b, a: 255)
end

public func rgba(r: int, g: int, b: int, a: int) -> raylib.Color
    return raylib.Color(r: r, g: g, b: b, a: a)
end

public func white() -> raylib.Color
    return raylib.rgb(255, 255, 255)
end

public func black() -> raylib.Color
    return raylib.rgb(0, 0, 0)
end

public func red() -> raylib.Color
    return raylib.rgb(230, 41, 55)
end

public func green() -> raylib.Color
    return raylib.rgb(0, 228, 48)
end

public func blue() -> raylib.Color
    return raylib.rgb(0, 121, 241)
end

public func yellow() -> raylib.Color
    return raylib.rgb(253, 249, 0)
end

public func rect(x: float, y: float, width: float, height: float) -> raylib.Rect
    return raylib.Rect(x: x, y: y, width: width, height: height)
end

public func vec2(x: float, y: float) -> raylib.Vector2
    return raylib.Vector2(x: x, y: y)
end

public func key_left() -> int
    return 263
end

public func key_right() -> int
    return 262
end

public func key_up() -> int
    return 265
end

public func key_down() -> int
    return 264
end

public func key_space() -> int
    return 32
end

public func key_escape() -> int
    return 256
end

public func binding_stub_smoke() -> result<void, core.Error>
    const native_loaded: bool = raylib.available()
    const native_path: text = raylib.loaded_path()
    const p1: raylib.Vector2 = raylib.vec2(3.0, 4.0)
    const p2: raylib.Vector2 = raylib.vec2(9.0, 12.0)
    const length: float = raylib.vector_length(p1)
    const distance: float = raylib.vector_distance(raylib.vec2(0.0, 0.0), p2)
    const eased: float = raylib.ease_quad_in_out(0.5, 0.0, 10.0, 1.0)
    const width: int = raylib.measure_text("raylib binding", 20)
    const fake_texture: raylib.Texture = raylib.Texture(id: 999, width: 32, height: 16)
    const fake_sound: raylib.Sound = raylib.Sound(id: 999)
    const empty_texture_load: result<raylib.Texture, core.Error> = raylib.load_texture("")
    const empty_sound_load: result<raylib.Sound, core.Error> = raylib.load_sound("")
    const window: raylib.Window = raylib.open_window("borealis-raylib-binding-stub", 640, 360, 60)?

    raylib.expect(length > 4.9 and length < 5.1, "vector_length should stay near 5")?
    raylib.expect(distance > 14.9 and distance < 15.1, "vector_distance should stay near 15")?
    raylib.expect(eased > 4.9 and eased < 5.1, "ease_quad_in_out midpoint should stay near 5")?
    raylib.expect(width > 0, "measure_text should return positive width")?
    raylib.expect(fake_texture.width == 32 and fake_texture.height == 16, "texture metadata should preserve stored dimensions")?

    if native_loaded
        raylib.expect(native_path != "", "loaded_path should be non-empty when Raylib is available")?
        raylib.require_available()?
    else
        raylib.expect(native_path == "", "loaded_path should stay empty when Raylib is unavailable")?
        const missing_native: result<void, core.Error> = raylib.require_available()
        match missing_native
            case success() ->
                return error("require_available should fail when Raylib is unavailable")
            case error(native_err) ->
                const native_error_message: text = native_err.message
                raylib.expect(native_error_message != "", "require_available should return a clear error")?
        end
    end

    match empty_texture_load
        case success(texture_asset) ->
            raylib.expect(texture_asset.id > 0, "load_texture success payload should stay valid")?
            return error("load_texture should reject empty paths")
        case error(texture_err) ->
            const texture_error_message: text = texture_err.message
            raylib.expect(texture_error_message == "raylib: texture path cannot be empty", "load_texture empty path should stay explicit")?
    end

    match empty_sound_load
        case success(sound_asset) ->
            raylib.expect(sound_asset.id > 0, "load_sound success payload should stay valid")?
            return error("load_sound should reject empty paths")
        case error(sound_err) ->
            const sound_error_message: text = sound_err.message
            raylib.expect(sound_error_message == "raylib: sound path cannot be empty", "load_sound empty path should stay explicit")?
    end

    raylib.begin_drawing(window, clear: raylib.black())?
    raylib.draw_rectangle(window, raylib.rect(24.0, 32.0, 80.0, 48.0), raylib.green())?
    raylib.draw_rectangle_lines(window, raylib.rect(20.0, 28.0, 88.0, 56.0), raylib.white(), thickness: 2.0)?
    raylib.draw_line(window, raylib.vec2(0.0, 0.0), raylib.vec2(120.0, 90.0), raylib.yellow())?
    raylib.draw_triangle(window, raylib.vec2(180.0, 40.0), raylib.vec2(150.0, 96.0), raylib.vec2(210.0, 96.0), raylib.red())?
    raylib.draw_circle(window, raylib.vec2(280.0, 80.0), 22.0, raylib.blue())?
    raylib.draw_circle_lines(window, raylib.vec2(280.0, 80.0), 28.0, raylib.white(), thickness: 2.0)?
    raylib.draw_ellipse(window, raylib.vec2(360.0, 80.0), 30.0, 18.0, raylib.rgb(180, 120, 255))?
    raylib.draw_text(window, "stub-safe raylib binding", 16, 120, 18, raylib.white())?
    raylib.end_drawing(window)?

    const invalid_texture_draw: result<void, core.Error> = raylib.draw_texture(window, fake_texture, raylib.vec2(420.0, 32.0))
    if native_loaded
        match invalid_texture_draw
            case success() ->
                return error("draw_texture should reject unknown texture handles with native Raylib")
            case error(texture_draw_err) ->
                const texture_draw_error_message: text = texture_draw_err.message
                raylib.expect(texture_draw_error_message != "", "draw_texture invalid handle should return a clear error")?
        end
    else
        match invalid_texture_draw
            case success() ->
            case error(_texture_draw_err) ->
                return error("draw_texture should stay stub-safe without native Raylib")
        end
    end

    const invalid_texture_draw_ex: result<void, core.Error> = raylib.draw_texture_ex(
        window,
        fake_texture,
        raylib.vec2(460.0, 72.0),
        rotation: 12.0,
        scale_amount: 1.25
    )
    if native_loaded
        match invalid_texture_draw_ex
            case success() ->
                return error("draw_texture_ex should reject unknown texture handles with native Raylib")
            case error(texture_draw_ex_err) ->
                const texture_draw_ex_error_message: text = texture_draw_ex_err.message
                raylib.expect(texture_draw_ex_error_message != "", "draw_texture_ex invalid handle should return a clear error")?
        end
    else
        match invalid_texture_draw_ex
            case success() ->
            case error(_texture_draw_ex_err) ->
                return error("draw_texture_ex should stay stub-safe without native Raylib")
        end
    end

    const invalid_sound_play: result<void, core.Error> = raylib.play_sound(fake_sound)
    match invalid_sound_play
        case success() ->
            return error("play_sound should reject unknown sound handles")
        case error(sound_play_err) ->
            const sound_play_error_message: text = sound_play_err.message
            raylib.expect(sound_play_error_message != "", "play_sound invalid handle should return a clear error")?
    end

    const invalid_sound_volume: result<void, core.Error> = raylib.set_sound_volume(fake_sound, 0.5)
    match invalid_sound_volume
        case success() ->
            return error("set_sound_volume should reject unknown sound handles")
        case error(sound_volume_err) ->
            const sound_volume_error_message: text = sound_volume_err.message
            raylib.expect(sound_volume_error_message != "", "set_sound_volume invalid handle should return a clear error")?
    end

    if native_loaded
        if raylib.is_key_down(window, raylib.key_escape())
        end
        if raylib.is_key_pressed(window, raylib.key_space())
        end
        if raylib.is_key_released(window, raylib.key_left())
        end
    else
        raylib.expect(raylib.is_key_down(window, raylib.key_escape()) == false, "escape should start false on stub")?
        raylib.expect(raylib.is_key_pressed(window, raylib.key_space()) == false, "space should start false on stub")?
        raylib.expect(raylib.is_key_released(window, raylib.key_left()) == false, "left should start false on stub")?
    end

    raylib.close_window(window)?
    return success()
end
