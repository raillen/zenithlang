    return raylib.zt_borealis_raylib_ease_sine_in(t, b, c, d)
end

public func ease_sine_out(t: float, b: float, c: float, d: float) -> float
    return raylib.zt_borealis_raylib_ease_sine_out(t, b, c, d)
end

public func ease_sine_in_out(t: float, b: float, c: float, d: float) -> float
    return raylib.zt_borealis_raylib_ease_sine_in_out(t, b, c, d)
end

public func ease_quad_in(t: float, b: float, c: float, d: float) -> float
    return raylib.zt_borealis_raylib_ease_quad_in(t, b, c, d)
end

