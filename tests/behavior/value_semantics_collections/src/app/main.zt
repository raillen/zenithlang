namespace app.main

func main() -> int
    var xs: list<int> = [1, 2, 3]
    var ys: list<int> = xs
    ys[1] = 9

    const list_score: int = (xs[1] * 10) + ys[1]

    const key_mode: text = "mode"
    const key_theme: text = "theme"
    const value_debug: text = "debug"
    const value_dark: text = "dark"

    var cfg1: map<text, text> = { key_mode: value_debug }
    var cfg2: map<text, text> = cfg1
    cfg2[key_theme] = value_dark

    const map_score: int = (len(cfg1) * 100) + len(cfg2)
    return list_score + map_score
end