namespace app.main

import std.collections as collections

func main() -> int
    var score: int = 0

    const grid_base: grid2d<text> = collections.grid2d_text_new(1, 2)
    const grid_left: grid2d<text> = collections.grid2d_text_set(grid_base, 0, 0, "oak")
    const grid_copy: grid2d<text> = grid_left
    const grid_right: grid2d<text> = collections.grid2d_text_set(grid_copy, 0, 0, "violet")
    if len(collections.grid2d_text_get(grid_left, 0, 0)) == 3
        score = score + 1
    end
    if len(collections.grid2d_text_get(grid_right, 0, 0)) == 6
        score = score + 1
    end

    const heap_base: pqueue<text> = collections.pqueue_text_new()
    const heap_one: pqueue<text> = collections.pqueue_text_push(heap_base, "m")
    const heap_copy: pqueue<text> = heap_one
    const heap_two: pqueue<text> = collections.pqueue_text_push(heap_copy, "a")
    if collections.pqueue_text_len(heap_one) == 1
        score = score + 1
    end
    if collections.pqueue_text_len(heap_two) == 2
        score = score + 1
    end

    const buf_base: circbuf<text> = collections.circbuf_text_new(3)
    const buf_one: circbuf<text> = collections.circbuf_text_push(buf_base, "alpha")
    const buf_copy: circbuf<text> = buf_one
    const buf_two: circbuf<text> = collections.circbuf_text_push(buf_copy, "beta")
    if collections.circbuf_text_len(buf_one) == 1
        score = score + 1
    end
    if collections.circbuf_text_len(buf_two) == 2
        score = score + 1
    end

    const map_base: btreemap<text,text> = collections.btreemap_text_new()
    const map_left: btreemap<text,text> = collections.btreemap_text_set(map_base, "kind", "oak")
    const map_copy: btreemap<text,text> = map_left
    const map_right: btreemap<text,text> = collections.btreemap_text_set(map_copy, "kind", "violet")
    if len(collections.btreemap_text_get(map_left, "kind")) == 3
        score = score + 1
    end
    if len(collections.btreemap_text_get(map_right, "kind")) == 6
        score = score + 1
    end

    const set_base: btreeset<text> = collections.btreeset_text_new()
    const set_one: btreeset<text> = collections.btreeset_text_insert(set_base, "alpha")
    const set_copy: btreeset<text> = set_one
    const set_two: btreeset<text> = collections.btreeset_text_insert(set_copy, "beta")
    const set_one_has_alpha: bool = collections.btreeset_text_contains(set_one, "alpha")
    const set_one_has_beta: bool = collections.btreeset_text_contains(set_one, "beta")
    if set_one_has_alpha
        if not set_one_has_beta
            score = score + 1
        end
    end
    if collections.btreeset_text_contains(set_two, "beta")
        score = score + 1
    end

    const cube_base: grid3d<text> = collections.grid3d_text_new(1, 1, 1)
    const cube_cold: grid3d<text> = collections.grid3d_text_set(cube_base, 0, 0, 0, "ice")
    const cube_copy: grid3d<text> = cube_cold
    const cube_warm: grid3d<text> = collections.grid3d_text_set(cube_copy, 0, 0, 0, "sunset")
    if len(collections.grid3d_text_get(cube_cold, 0, 0, 0)) == 3
        score = score + 1
    end
    if len(collections.grid3d_text_get(cube_warm, 0, 0, 0)) == 6
        score = score + 1
    end

    return score
end
