namespace app.main

import std.format as format

func main() -> int
    const ok: text = "ok"
    const sample_ms: int = 1704067200000

    const k1: text = format.hex(255)
    const m1: map<text, text> = { k1: ok }
    const v1: text = m1["ff"]

    const k2: text = format.hex(-26)
    const m2: map<text, text> = { k2: ok }
    const v2: text = m2["-1a"]

    const k3: text = format.bin(10)
    const m3: map<text, text> = { k3: ok }
    const v3: text = m3["1010"]

    const k4: text = format.bytes(1536, style: format.BytesStyle.Binary)
    const m4: map<text, text> = { k4: ok }
    const v4: text = m4["1.5 KiB"]

    const k5: text = format.bytes(1500, style: format.BytesStyle.Decimal, decimals: 2)
    const m5: map<text, text> = { k5: ok }
    const v5: text = m5["1.50 KB"]

    const n1: text = format.number(12.345, decimals: 2)
    const p1: text = format.percent(0.125, decimals: 1)
    const d1: text = format.date(sample_ms)
    const dt1: text = format.datetime(sample_ms)
    const dp1: text = format.date_pattern(sample_ms, "yyyy-MM-dd")
    const dtp1: text = format.datetime_pattern(sample_ms, "yyyy-MM-dd HH:mm:ss")

    if len(v1) == 0 or len(v2) == 0 or len(v3) == 0 or len(v4) == 0 or len(v5) == 0 or len(n1) == 0 or len(p1) == 0 or len(d1) == 0 or len(dt1) == 0 or len(dp1) == 0 or len(dtp1) == 0
        return 9
    end

    return 0
end
