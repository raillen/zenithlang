namespace app.main

import std.format as format

func main() -> int
    const ok: text = "ok"

    const k1: text = format.hex(255)
    const m1: map<text, text> = { k1: ok }
    const v1: text = m1["ff"]

    const k2: text = format.hex(-26)
    const m2: map<text, text> = { k2: ok }
    const v2: text = m2["-1a"]

    const k3: text = format.bin(10)
    const m3: map<text, text> = { k3: ok }
    const v3: text = m3["1010"]

    const k4: text = format.bytes(1536, style: format.style_binary())
    const m4: map<text, text> = { k4: ok }
    const v4: text = m4["1.5 KiB"]

    const k5: text = format.bytes(1500, style: format.style_decimal(), decimals: 2)
    const m5: map<text, text> = { k5: ok }
    const v5: text = m5["1.50 KB"]

    const k6: text = format.bytes_binary(1024)
    const m6: map<text, text> = { k6: ok }
    const v6: text = m6["1.0 KiB"]

    const k7: text = format.bytes_decimal(1000)
    const m7: map<text, text> = { k7: ok }
    const v7: text = m7["1.0 KB"]

    if len(v1) == 0 or len(v2) == 0 or len(v3) == 0 or len(v4) == 0 or len(v5) == 0 or len(v6) == 0 or len(v7) == 0
        return 9
    end

    return 0
end
