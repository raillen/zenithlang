namespace app.main

import app.model as model

func is_missing(sample: optional<model.Profile>) -> bool
    match sample
        case value present ->
            return false
        case none ->
            return true
    end
end

func main() -> int
    const found: optional<model.Profile> = model.find_profile(1)
    const copied: optional<model.Profile> = found
    const missing: optional<model.Profile> = model.find_profile(99)
    const direct: model.Profile = model.make_profile()
    const wrapped_direct: optional<model.Profile> = direct
    const returned_optional: optional<model.Profile> = model.return_optional_profile()
    var assigned: optional<model.Profile> = none
    var slot: model.Slot = model.empty_slot()
    const built_slot: model.Slot = model.Slot(profile: model.make_profile())

    assigned = model.make_profile()
    slot.profile = model.make_profile()

    if is_missing(missing) == false
        return 1
    end

    if model.unwrap_name(wrapped_direct) != "Lina"
        return 10
    end

    if model.unwrap_name(assigned) != "Lina"
        return 11
    end

    if model.unwrap_name(returned_optional) != "Lina"
        return 12
    end

    if model.unwrap_name(model.make_profile()) != "Lina"
        return 13
    end

    if model.slot_name(slot) != "Lina"
        return 14
    end

    if model.slot_name(built_slot) != "Lina"
        return 15
    end

    var left: model.Profile = model.empty_profile()
    var right: model.Profile = model.empty_profile()

    match found
        case value profile ->
            left = profile
        case none ->
            return 2
    end

    match copied
        case value profile ->
            right = profile
        case none ->
            return 3
    end

    if left.pos.x != 3
        return 4
    end

    if left.pos.y != 4
        return 5
    end

    if left.tags[0] != "wind"
        return 6
    end

    right.tags[0] = "stone"

    if left.tags[0] != "wind"
        return 7
    end

    if right.tags[0] != "stone"
        return 8
    end

    if right.name != "Lina"
        return 9
    end

    if direct.tags[0] != "wind"
        return 16
    end

    return 0
end
