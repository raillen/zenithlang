namespace app.main

extern c
    func zt_borealis_open_window(title: text, width: int, height: int, target_fps: int, backend_id: int) -> result<int, core.Error>
    func zt_borealis_close_window(window_id: int) -> result<void, core.Error>
    func zt_borealis_begin_frame(window_id: int, clear_r: int, clear_g: int, clear_b: int, clear_a: int) -> result<void, core.Error>
    func zt_borealis_end_frame(window_id: int) -> result<void, core.Error>
    func zt_borealis_draw_rect(window_id: int, x: float, y: float, width: float, height: float, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_draw_text(window_id: int, value: text, x: int, y: int, size: int, color_r: int, color_g: int, color_b: int, color_a: int) -> result<void, core.Error>
    func zt_borealis_is_key_down(window_id: int, input_code: int) -> bool
    func zt_borealis_is_key_pressed(window_id: int, input_code: int) -> bool
    func zt_borealis_is_key_released(window_id: int, input_code: int) -> bool
end

func expect_not(value: bool, message: text) -> result<void, core.Error>
    if value
        return error(message)
    end
    return success()
end

func main() -> result<void, core.Error>
    -- backend_id 0 = deterministic stub backend.
    -- This keeps the fallback test independent from any local Raylib install.
    const window_id: int = zt_borealis_open_window("borealis-backend-fallback-stub", 640, 360, 60, 0)?
    const key_code: int = 32

    zt_borealis_begin_frame(window_id, 20, 24, 32, 255)?
    zt_borealis_draw_rect(window_id, 64.0, 80.0, 120.0, 90.0, 255, 170, 40, 255)?
    zt_borealis_draw_text(window_id, "fallback", 16, 16, 18, 255, 255, 255, 255)?
    zt_borealis_end_frame(window_id)?

    expect_not(zt_borealis_is_key_down(window_id, key_code), "key_down should start false")?
    expect_not(zt_borealis_is_key_pressed(window_id, key_code), "key_pressed should start false")?
    expect_not(zt_borealis_is_key_released(window_id, key_code), "key_released should start false")?

    zt_borealis_close_window(window_id)?
    return success()
end
