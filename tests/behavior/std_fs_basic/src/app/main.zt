namespace app.main

import std.fs as fs

func main() -> result<void, text>
    const path: text = ".ztc-tmp/std_fs_basic.txt"

    fs.write_text(path, "Zenith FS baseline")?

    const exists_ok: bool = fs.exists(path)
    if exists_ok == false
        return error("std.fs.exists returned false after write_text")
    end

    const content: text = fs.read_text(path)?
    if len(content) == 0
        return error("std.fs.read_text returned empty content")
    end

    return success()
end