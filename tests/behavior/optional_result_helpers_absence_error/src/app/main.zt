namespace app.main

func maybe_score() -> optional<int>
    return none
end

func parse_score() -> result<int, text>
    return error("bad")
end

func main() -> int
    const maybe: optional<int> = maybe_score()
    if maybe.is_some()
        return 1
    end
    if maybe.is_none() == false
        return 2
    end
    if maybe.or(9) != 9
        return 3
    end

    const parsed: result<int, text> = parse_score()
    if parsed.is_success()
        return 4
    end
    if parsed.is_error() == false
        return 5
    end

    return 0
end

