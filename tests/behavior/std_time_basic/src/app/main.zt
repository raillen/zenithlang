namespace app.main

import std.time as time

func main() -> result<void, core.Error>
    const start: time.Instant = time.now()
    const one_ms: time.Duration = time.milliseconds(1)

    time.sleep(one_ms)?

    const elapsed: time.Duration = time.since(start)
    const progressed: time.Instant = time.add(start, elapsed)
    if time.to_unix_ms(progressed) < time.to_unix_ms(start)
        return error("std.time.since returned negative elapsed time")
    end

    const unix_ms_start: int = time.to_unix_ms(start)
    const from_ms: time.Instant = time.from_unix_ms(unix_ms_start)
    if time.to_unix_ms(from_ms) != unix_ms_start
        return error("std.time from/to unix_ms roundtrip failed")
    end

    const unix_s: int = time.to_unix(start)
    const from_s: time.Instant = time.from_unix(unix_s)
    if time.to_unix(from_s) != unix_s
        return error("std.time from/to unix roundtrip failed")
    end

    const later: time.Instant = time.add(start, time.seconds(2))
    const back: time.Instant = time.sub(later, time.seconds(2))
    if time.to_unix_ms(back) != unix_ms_start
        return error("std.time add/sub should preserve instant")
    end

    const diff_forward: time.Duration = time.diff(start, later)
    const shifted_ms: int = time.to_unix_ms(time.add(start, diff_forward)) - time.to_unix_ms(start)
    if shifted_ms != 2000
        return error("std.time diff should preserve signed duration in ms")
    end

    const anchor: time.Instant = time.now()
    const future: time.Instant = time.add(anchor, time.minutes(1))
    const remaining: time.Duration = time.until(future)
    if time.to_unix_ms(time.add(anchor, remaining)) <= time.to_unix_ms(anchor)
        return error("std.time until should be positive for a future instant")
    end

    return success()
end