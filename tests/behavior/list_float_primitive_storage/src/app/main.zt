namespace app.main

func approx(left: float, right: float, epsilon: float = 0.001) -> bool
    var diff: float = left - right
    if diff < 0.0
        diff = 0.0 - diff
    end
    return diff < epsilon
end

func main() -> int
    var values: list<float> = [1.5, 2.25, 3.75]
    values[1] = 4.5

    const middle: list<float> = values[1..2]

    if len(values) != 3
        return 1
    end
    if len(middle) != 2
        return 2
    end
    if approx(values[0], 1.5) == false
        return 3
    end
    if approx(values[1], 4.5) == false
        return 4
    end
    if approx(middle[0], 4.5) == false
        return 5
    end
    if approx(middle[1], 3.75) == false
        return 6
    end

    return 0
end

