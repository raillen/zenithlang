namespace app.main

enum Shape
    Circle(radius: int)
    Rectangle(width: int, height: int)
    Point
end

func get_area(s: Shape) -> int
    match s
        case Shape.Circle(r) ->
            return r * r
        case Shape.Rectangle(w, h) ->
            return w * h
        case Shape.Point ->
            return 0
    end
end

func main() -> int
    const c: Shape = Shape.Circle(radius: 10)
    const r: Shape = Shape.Rectangle(width: 5, height: 4)
    const p: Shape = Shape.Point

    if get_area(c) != 100
        return 1
    end

    if get_area(r) != 20
        return 2
    end

    if get_area(p) != 0
        return 3
    end

    return 0
end
