namespace borealis.game.services

public struct HttpRequest
    method: text = "GET"
    url: text
    body: text = ""
end

public struct HttpResponse
    status: int
    body: text
end

public struct CloudState
    connected: bool
    provider: text
end

public var request_count_total: int = 0
public var last_request_url: text = ""
public var cloud_values: map<text, text> = {}
public var cloud_present: map<text, bool> = {}
public var cloud_provider_counts: map<text, int> = {}

public func http_send(request: services.HttpRequest) -> result<services.HttpResponse, core.Error>
    if request.url == ""
        return error("services: url cannot be empty")
    end

    const method: text = services.normalize_method(request.method)
    const body: text = services.normalize_body(request.body)
    request_count_total = request_count_total + 1
    last_request_url = request.url

    if body == ""
        const response_body: text = fmt "{method} {request.url}"
        return success(services.HttpResponse(status: 200, body: response_body))
    end

    const response_body: text = fmt "{method} {request.url} body={body}"
    return success(services.HttpResponse(status: 200, body: response_body))
end

public func cloud_connect(provider: text) -> services.CloudState
    if provider == ""
        return services.CloudState(connected: false, provider: "")
    end

    return services.CloudState(connected: true, provider: provider)
end

public func cloud_disconnect(state: services.CloudState) -> services.CloudState
    const provider_name: text = state.provider
    if provider_name == ""
        return services.CloudState(connected: false, provider: "")
    end

    return services.CloudState(connected: false, provider: provider_name)
end

public func cloud_is_connected(state: services.CloudState) -> bool
    const connected: bool = state.connected
    return connected
end

public func cloud_upload(
    state: services.CloudState,
    name: text,
    data: text
) -> result<void, core.Error>
    services.require_cloud_connection(state)?
    if name == ""
        return error("services: cloud name cannot be empty")
    end

    const provider_name: text = state.provider
    const key: text = services.cloud_key(provider_name, name)
    const was_present: bool = services.bool_or(cloud_present, key, false)
    var next_values: map<text, text> = cloud_values
    var next_present: map<text, bool> = cloud_present
    var next_counts: map<text, int> = cloud_provider_counts
    const stored_data: text = data
    next_values[key] = stored_data
    next_present[key] = true

    if was_present == false
        next_counts[provider_name] = services.int_or(cloud_provider_counts, provider_name, 0) + 1
    end

    cloud_values = next_values
    cloud_present = next_present
    cloud_provider_counts = next_counts
    return success()
end

public func cloud_download(
    state: services.CloudState,
    name: text
) -> result<optional<text>, core.Error>
    services.require_cloud_connection(state)?
    if name == ""
        return error("services: cloud name cannot be empty")
    end

    const provider_name: text = state.provider
    const key: text = services.cloud_key(provider_name, name)
    if services.bool_or(cloud_present, key, false) == false
        const missing_value: optional<text> = none
        return success(missing_value)
    end

    return success(cloud_values.get(key))
end

public func cloud_remove(
    state: services.CloudState,
    name: text
) -> result<void, core.Error>
    services.require_cloud_connection(state)?
    if name == ""
        return error("services: cloud name cannot be empty")
    end

    const provider_name: text = state.provider
    const key: text = services.cloud_key(provider_name, name)
    const was_present: bool = services.bool_or(cloud_present, key, false)
    var next_values: map<text, text> = cloud_values
    var next_present: map<text, bool> = cloud_present
    var next_counts: map<text, int> = cloud_provider_counts
    const cleared_data: text = ""
    next_values[key] = cleared_data
    next_present[key] = false

    if was_present
        const current_count: int = services.int_or(cloud_provider_counts, provider_name, 0)
        if current_count > 0
            next_counts[provider_name] = current_count - 1
        end
    end

    cloud_values = next_values
    cloud_present = next_present
    cloud_provider_counts = next_counts
    return success()
end

public func cloud_exists(
    state: services.CloudState,
    name: text
) -> result<bool, core.Error>
    services.require_cloud_connection(state)?
    if name == ""
        return error("services: cloud name cannot be empty")
    end

    const provider_name: text = state.provider
    const key: text = services.cloud_key(provider_name, name)
    return success(services.bool_or(cloud_present, key, false))
end

public func cloud_entry_count(state: services.CloudState) -> result<int, core.Error>
    services.require_cloud_connection(state)?
    const provider_name: text = state.provider
    return success(services.int_or(cloud_provider_counts, provider_name, 0))
end

public func request_count() -> int
    return request_count_total
end

public func last_url() -> text
    return last_request_url
end

public func reset() -> void
    request_count_total = 0
    last_request_url = ""
    cloud_values = {}
    cloud_present = {}
    cloud_provider_counts = {}
end

public func require_cloud_connection(state: services.CloudState) -> result<void, core.Error>
    const connected: bool = state.connected
    const provider_name: text = state.provider
    if connected == false
        return error("services: cloud is disconnected")
    end
    if provider_name == ""
        return error("services: provider cannot be empty")
    end
    return success()
end

public func normalize_method(method: text) -> text
    if method == ""
        return "GET"
    end
    return method
end

public func normalize_body(body: text) -> text
    return body
end

public func cloud_key(provider: text, name: text) -> text
    return fmt "{provider}::{name}"
end

public func bool_or(values: map<text, bool>, key: text, fallback: bool) -> bool
    const maybe: optional<bool> = values.get(key)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func int_or(values: map<text, int>, key: text, fallback: int) -> int
    const maybe: optional<int> = values.get(key)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end
