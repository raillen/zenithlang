namespace borealis.game.ui.hud

public struct HudValues
    health: int = 100
    score: int = 0
    ammo: int = 0
end

public struct HudPoint
    x: float
    y: float
end

public struct HudWidget
    id: text
    text_value: text
    visible: bool
    x: float
    y: float
    value: int
end

public var hud_exists: map<text, bool> = {}
public var hud_visible: map<text, bool> = {}
public var hud_text: map<text, text> = {}
public var hud_value: map<text, int> = {}
public var hud_x: map<text, float> = {}
public var hud_y: map<text, float> = {}
public var hud_widget_count_value: int = 0

public func defaults() -> hud.HudValues
    return hud.HudValues()
end

public func set_health(current: hud.HudValues, value: int) -> hud.HudValues
    var next: hud.HudValues = current
    next.health = value
    return next
end

public func add_score(current: hud.HudValues, value: int) -> hud.HudValues
    var next: hud.HudValues = current
    next.score = current.score + value
    return next
end

public func bool_or(values: map<text, bool>, id: text, fallback: bool) -> bool
    const maybe: optional<bool> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func text_or(values: map<text, text>, id: text, fallback: text) -> text
    const maybe: optional<text> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func int_or(values: map<text, int>, id: text, fallback: int) -> int
    const maybe: optional<int> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func float_or(values: map<text, float>, id: text, fallback: float) -> float
    const maybe: optional<float> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func bool_set(values: map<text, bool>, id: text, value: bool) -> map<text, bool>
    var next: map<text, bool> = values
    next[id] = value
    return next
end

public func text_set(values: map<text, text>, id: text, value: text) -> map<text, text>
    var next: map<text, text> = values
    next[id] = value
    return next
end

public func int_set(values: map<text, int>, id: text, value: int) -> map<text, int>
    var next: map<text, int> = values
    next[id] = value
    return next
end

public func float_set(values: map<text, float>, id: text, value: float) -> map<text, float>
    var next: map<text, float> = values
    next[id] = value
    return next
end

public func add_widget(id: text, text_value: text = "") -> result<void, core.Error>
    if id == ""
        return error("hud: widget id cannot be empty")
    end
    if hud.has_widget(id) == false
        hud_widget_count_value = hud_widget_count_value + 1
    end
    hud_exists = hud.bool_set(hud_exists, id, true)
    hud_visible = hud.bool_set(hud_visible, id, true)
    hud_text = hud.text_set(hud_text, id, text_value)
    hud_value = hud.int_set(hud_value, id, 0)
    hud_x = hud.float_set(hud_x, id, 0.0)
    hud_y = hud.float_set(hud_y, id, 0.0)
    return success()
end

public func remove_widget(id: text) -> result<void, core.Error>
    if id == ""
        return error("hud: widget id cannot be empty")
    end
    if hud.has_widget(id)
        hud_widget_count_value = hud_widget_count_value - 1
    end
    hud_exists = hud.bool_set(hud_exists, id, false)
    hud_visible = hud.bool_set(hud_visible, id, false)
    return success()
end

public func has_widget(id: text) -> bool
    return hud.bool_or(hud_exists, id, false)
end

public func widget_count() -> int
    return hud_widget_count_value
end

public func show(id: text) -> result<void, core.Error>
    return hud.set_visible(id, true)
end

public func hide(id: text) -> result<void, core.Error>
    return hud.set_visible(id, false)
end

public func set_visible(id: text, visible: bool) -> result<void, core.Error>
    if hud.has_widget(id) == false
        return error("hud: widget not found")
    end
    hud_visible = hud.bool_set(hud_visible, id, visible)
    return success()
end

public func is_visible(id: text) -> bool
    if hud.has_widget(id) == false
        return false
    end
    return hud.bool_or(hud_visible, id, true)
end

public func set_position(id: text, x: float, y: float) -> result<void, core.Error>
    if hud.has_widget(id) == false
        return error("hud: widget not found")
    end
    hud_x = hud.float_set(hud_x, id, x)
    hud_y = hud.float_set(hud_y, id, y)
    return success()
end

public func position(id: text) -> hud.HudPoint
    return hud.HudPoint(
        x: hud.float_or(hud_x, id, 0.0),
        y: hud.float_or(hud_y, id, 0.0)
    )
end

public func set_value(id: text, value: int) -> result<void, core.Error>
    if hud.has_widget(id) == false
        return error("hud: widget not found")
    end
    hud_value = hud.int_set(hud_value, id, value)
    return success()
end

public func get_value(id: text) -> int
    return hud.int_or(hud_value, id, 0)
end

public func set_text(id: text, value: text) -> result<void, core.Error>
    if hud.has_widget(id) == false
        return error("hud: widget not found")
    end
    hud_text = hud.text_set(hud_text, id, value)
    return success()
end

public func get_text(id: text) -> text
    return hud.text_or(hud_text, id, "")
end

public func inspect(id: text) -> hud.HudWidget
    return hud.HudWidget(
        id: id,
        text_value: hud.get_text(id),
        visible: hud.is_visible(id),
        x: hud.float_or(hud_x, id, 0.0),
        y: hud.float_or(hud_y, id, 0.0),
        value: hud.get_value(id)
    )
end

public func reset() -> void
    hud_exists = {}
    hud_visible = {}
    hud_text = {}
    hud_value = {}
    hud_x = {}
    hud_y = {}
    hud_widget_count_value = 0
end
