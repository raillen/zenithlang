namespace borealis.game.ui

public struct ButtonState
    hovered: bool
    pressed: bool
    clicked: bool
end

public struct WidgetState
    hovered: bool
    pressed: bool
    clicked: bool
    focused: bool
    visible: bool
end

public struct Widget
    id: text
    kind: text
    label: text
    area: game.Rect
    visible: bool
    focused: bool
    value: float
    checked: bool
    text_value: text
end

public func widget(id: text, kind: text, label: text, area: game.Rect) -> ui.Widget
    return ui.Widget(
        id: id,
        kind: kind,
        label: label,
        area: area,
        visible: true,
        focused: false,
        value: 0.0,
        checked: false,
        text_value: ""
    )
end

public func panel(id: text, area: game.Rect) -> ui.Widget
    return ui.widget(id, "panel", "", area)
end

public func label_widget(id: text, value: text, area: game.Rect) -> ui.Widget
    var next: ui.Widget = ui.widget(id, "label", value, area)
    next.text_value = value
    return next
end

public func checkbox(
    id: text,
    label: text,
    area: game.Rect,
    checked: bool = false
) -> ui.Widget
    var next: ui.Widget = ui.widget(id, "checkbox", label, area)
    next.checked = checked
    return next
end

public func slider(id: text, label: text, area: game.Rect, value: float) -> ui.Widget
    var next: ui.Widget = ui.widget(id, "slider", label, area)
    next.value = ui.clamp_unit(value)
    return next
end

public func text_input(id: text, area: game.Rect, value: text = "") -> ui.Widget
    var next: ui.Widget = ui.widget(id, "text_input", "", area)
    next.text_value = value
    return next
end

public func image(id: text, asset_key: text, area: game.Rect) -> ui.Widget
    var next: ui.Widget = ui.widget(id, "image", "", area)
    next.text_value = asset_key
    return next
end

public func container(id: text, area: game.Rect) -> ui.Widget
    return ui.widget(id, "container", "", area)
end

public func point_in_rect(point: game.Vector2, area: game.Rect) -> bool
    return point.x >= area.x and
           point.x <= (area.x + area.width) and
           point.y >= area.y and
           point.y <= (area.y + area.height)
end

public func hover(area: game.Rect, mouse: game.Vector2) -> bool
    return ui.point_in_rect(mouse, area)
end

public func click(area: game.Rect, mouse: game.Vector2, mouse_pressed: bool) -> bool
    return ui.hover(area, mouse) and mouse_pressed
end

public func button(
    area: game.Rect,
    mouse: game.Vector2,
    mouse_down: bool,
    mouse_pressed: bool
) -> ui.ButtonState
    const hovered: bool = ui.point_in_rect(mouse, area)
    return ui.ButtonState(
        hovered: hovered,
        pressed: hovered and mouse_down,
        clicked: hovered and mouse_pressed
    )
end

public func state(
    current: ui.Widget,
    mouse: game.Vector2,
    mouse_down: bool,
    mouse_pressed: bool
) -> ui.WidgetState
    if current.visible == false
        return ui.WidgetState(
            hovered: false,
            pressed: false,
            clicked: false,
            focused: current.focused,
            visible: false
        )
    end

    const hovered: bool = ui.hover(current.area, mouse)
    return ui.WidgetState(
        hovered: hovered,
        pressed: hovered and mouse_down,
        clicked: hovered and mouse_pressed,
        focused: current.focused,
        visible: true
    )
end

public func focus(current: ui.Widget, focused: bool = true) -> ui.Widget
    var next: ui.Widget = current
    next.focused = focused
    return next
end

public func show(current: ui.Widget) -> ui.Widget
    return ui.set_visible(current, true)
end

public func hide(current: ui.Widget) -> ui.Widget
    return ui.set_visible(current, false)
end

public func set_visible(current: ui.Widget, visible: bool) -> ui.Widget
    var next: ui.Widget = current
    next.visible = visible
    return next
end

public func set_value(current: ui.Widget, value: float) -> ui.Widget
    var next: ui.Widget = current
    next.value = ui.clamp_unit(value)
    return next
end

public func set_checked(current: ui.Widget, checked: bool) -> ui.Widget
    var next: ui.Widget = current
    next.checked = checked
    return next
end

public func set_text(current: ui.Widget, value: text) -> ui.Widget
    var next: ui.Widget = current
    next.text_value = value
    return next
end

public func layout_vertical(area: game.Rect, index: int, gap: float = 8.0) -> game.Rect
    var y: float = area.y
    var cursor: int = 0
    while cursor < index
        y = y + area.height + gap
        cursor = cursor + 1
    end
    return game.rect(area.x, y, area.width, area.height)
end

public func layout_row(area: game.Rect, index: int, gap: float = 8.0) -> game.Rect
    var x: float = area.x
    var cursor: int = 0
    while cursor < index
        x = x + area.width + gap
        cursor = cursor + 1
    end
    return game.rect(x, area.y, area.width, area.height)
end

public func clamp_unit(value: float) -> float
    if value < 0.0
        return 0.0
    end
    if value > 1.0
        return 1.0
    end
    return value
end

public func label(value: text) -> text
    return value
end
