namespace borealis.game.events

public struct EventMessage
    id: int
    name: text
    payload: text
end

public var last_event_name: text = ""
public var last_event_payload: text = ""
public var emit_count: int = 0
public var event_next_id: int = 1
public var event_cursor: int = 1
public var event_names: map<int, text> = {}
public var event_payloads: map<int, text> = {}
public var event_pending: map<int, bool> = {}
public var event_name_count: map<text, int> = {}

public var subscription_next_id: int = 1
public var subscription_names: map<int, text> = {}
public var subscription_listeners: map<int, text> = {}
public var subscription_once_flags: map<int, bool> = {}
public var subscription_active: map<int, bool> = {}

public var delivery_next_id: int = 1
public var delivery_event_ids: map<int, int> = {}
public var delivery_names: map<int, text> = {}
public var delivery_payloads: map<int, text> = {}
public var delivery_listeners: map<int, text> = {}
public var delivery_pending: map<int, bool> = {}

public func emit(name: text, payload: text = "") -> result<void, core.Error>
    events.emit_internal(name, payload)?
    return success()
end

public func queue(name: text, payload: text = "") -> result<void, core.Error>
    return events.emit(name, payload)
end

public func dispatch(name: text, payload: text = "") -> result<int, core.Error>
    return events.emit_internal(name, payload)
end

public func on(name: text, listener: text) -> result<void, core.Error>
    return events.register(name, listener, false)
end

public func once(name: text, listener: text) -> result<void, core.Error>
    return events.register(name, listener, true)
end

public func off(name: text, listener: text) -> result<void, core.Error>
    if name == ""
        return error("events: name cannot be empty")
    end
    if listener == ""
        return error("events: listener cannot be empty")
    end

    var next_active: map<int, bool> = subscription_active
    var probe: int = 1
    while probe < subscription_next_id
        if events.event_bool_or(subscription_active, probe, false)
            if events.event_text_or(subscription_names, probe, "") == name
                if events.event_text_or(subscription_listeners, probe, "") == listener
                    next_active[probe] = false
                end
            end
        end
        probe = probe + 1
    end

    subscription_active = next_active
    return success()
end

public func clear(name: text = "") -> result<void, core.Error>
    var next_active: map<int, bool> = subscription_active
    var probe: int = 1
    while probe < subscription_next_id
        if events.event_bool_or(subscription_active, probe, false)
            if name == "" or events.event_text_or(subscription_names, probe, "") == name
                next_active[probe] = false
            end
        end
        probe = probe + 1
    end

    subscription_active = next_active
    return success()
end

public func is_registered(name: text, listener: text) -> bool
    if name == "" or listener == ""
        return false
    end

    return events.find_active_subscription_id(name, listener) > 0
end

public func listener_count(name: text = "") -> int
    var total: int = 0
    var probe: int = 1
    while probe < subscription_next_id
        if events.event_bool_or(subscription_active, probe, false)
            if name == "" or events.event_text_or(subscription_names, probe, "") == name
                total = total + 1
            end
        end
        probe = probe + 1
    end
    return total
end

public func peek() -> optional<events.EventMessage>
    const id: int = events.first_pending_id()
    if id <= 0
        return none
    end
    return events.event_message(id)
end

public func poll() -> optional<events.EventMessage>
    const id: int = events.first_pending_id()
    if id <= 0
        return none
    end

    const message: events.EventMessage = events.event_message(id)
    event_pending = events.event_bool_set(event_pending, id, false)
    event_cursor = id + 1
    events.normalize_cursor()
    return message
end

public func dispatch_next() -> optional<events.EventMessage>
    return events.poll()
end

public func listener_peek(listener: text) -> optional<events.EventMessage>
    const delivery_id: int = events.first_listener_delivery_id(listener)
    if delivery_id <= 0
        return none
    end
    return events.delivery_message(delivery_id)
end

public func listener_poll(listener: text) -> optional<events.EventMessage>
    const delivery_id: int = events.first_listener_delivery_id(listener)
    if delivery_id <= 0
        return none
    end

    const message: events.EventMessage = events.delivery_message(delivery_id)
    delivery_pending = events.event_bool_set(delivery_pending, delivery_id, false)
    return message
end

public func clear_pending(name: text = "") -> result<void, core.Error>
    var next_pending: map<int, bool> = event_pending
    var probe: int = 1
    while probe < event_next_id
        if events.event_bool_or(event_pending, probe, false)
            if name == "" or events.event_text_or(event_names, probe, "") == name
                next_pending[probe] = false
            end
        end
        probe = probe + 1
    end

    event_pending = next_pending
    events.normalize_cursor()
    return success()
end

public func clear_listener(listener: text) -> result<void, core.Error>
    if listener == ""
        return error("events: listener cannot be empty")
    end

    var next_pending: map<int, bool> = delivery_pending
    var probe: int = 1
    while probe < delivery_next_id
        if events.event_bool_or(delivery_pending, probe, false)
            if events.event_text_or(delivery_listeners, probe, "") == listener
                next_pending[probe] = false
            end
        end
        probe = probe + 1
    end

    delivery_pending = next_pending
    return success()
end

public func has_pending() -> bool
    return events.first_pending_id() > 0
end

public func pending_count() -> int
    var total: int = 0
    var probe: int = 1
    while probe < event_next_id
        if events.event_bool_or(event_pending, probe, false)
            total = total + 1
        end
        probe = probe + 1
    end
    return total
end

public func listener_has_pending(listener: text) -> bool
    return events.first_listener_delivery_id(listener) > 0
end

public func listener_pending_count(listener: text) -> int
    if listener == ""
        return 0
    end

    var total: int = 0
    var probe: int = 1
    while probe < delivery_next_id
        if events.event_bool_or(delivery_pending, probe, false)
            if events.event_text_or(delivery_listeners, probe, "") == listener
                total = total + 1
            end
        end
        probe = probe + 1
    end
    return total
end

public func count_named(name: text) -> int
    return events.event_int_or(event_name_count, name, 0)
end

public func reset() -> void
    last_event_name = ""
    last_event_payload = ""
    emit_count = 0
    event_next_id = 1
    event_cursor = 1
    event_names = {}
    event_payloads = {}
    event_pending = {}
    event_name_count = {}

    subscription_next_id = 1
    subscription_names = {}
    subscription_listeners = {}
    subscription_once_flags = {}
    subscription_active = {}

    delivery_next_id = 1
    delivery_event_ids = {}
    delivery_names = {}
    delivery_payloads = {}
    delivery_listeners = {}
    delivery_pending = {}
end

public func last_name() -> text
    return last_event_name
end

public func last_payload() -> text
    return last_event_payload
end

public func count() -> int
    return emit_count
end

public func first_pending_id() -> int
    var probe: int = event_cursor
    while probe < event_next_id
        if events.event_bool_or(event_pending, probe, false)
            return probe
        end
        probe = probe + 1
    end
    return 0
end

public func first_listener_delivery_id(listener: text) -> int
    if listener == ""
        return 0
    end

    var probe: int = 1
    while probe < delivery_next_id
        if events.event_bool_or(delivery_pending, probe, false)
            if events.event_text_or(delivery_listeners, probe, "") == listener
                return probe
            end
        end
        probe = probe + 1
    end
    return 0
end

public func normalize_cursor() -> void
    const next_id: int = events.first_pending_id()
    if next_id > 0
        event_cursor = next_id
    else
        event_cursor = event_next_id
    end
end

public func event_message(id: int) -> events.EventMessage
    return events.EventMessage(
        id: id,
        name: events.event_text_or(event_names, id, ""),
        payload: events.event_text_or(event_payloads, id, "")
    )
end

public func delivery_message(delivery_id: int) -> events.EventMessage
    return events.EventMessage(
        id: events.event_int_by_id_or(delivery_event_ids, delivery_id, 0),
        name: events.event_text_or(delivery_names, delivery_id, ""),
        payload: events.event_text_or(delivery_payloads, delivery_id, "")
    )
end

public func event_name(id: int) -> text
    return events.event_text_or(event_names, id, "")
end

public func event_payload(id: int) -> text
    return events.event_text_or(event_payloads, id, "")
end

public func emit_internal(name: text, payload: text) -> result<int, core.Error>
    if name == ""
        return error("events: name cannot be empty")
    end

    const id: int = event_next_id
    event_next_id = event_next_id + 1
    event_names = events.event_text_set(event_names, id, name)
    event_payloads = events.event_text_set(event_payloads, id, payload)
    event_pending = events.event_bool_set(event_pending, id, true)
    event_name_count = events.event_int_set(
        event_name_count,
        name,
        events.event_int_or(event_name_count, name, 0) + 1
    )

    last_event_name = name
    last_event_payload = payload
    emit_count = emit_count + 1

    if event_cursor >= id
        event_cursor = id
    end

    const delivered: int = events.route_to_listeners(id, name, payload)
    return success(delivered)
end

public func register(name: text, listener: text, once_only: bool) -> result<void, core.Error>
    if name == ""
        return error("events: name cannot be empty")
    end
    if listener == ""
        return error("events: listener cannot be empty")
    end

    const existing_id: int = events.find_subscription_slot(name, listener)
    if existing_id > 0
        var next_once: map<int, bool> = subscription_once_flags
        var next_active: map<int, bool> = subscription_active
        next_once[existing_id] = once_only
        next_active[existing_id] = true
        subscription_once_flags = next_once
        subscription_active = next_active
        return success()
    end

    const subscription_id: int = subscription_next_id
    subscription_next_id = subscription_next_id + 1

    var next_names: map<int, text> = subscription_names
    var next_listeners: map<int, text> = subscription_listeners
    var next_once: map<int, bool> = subscription_once_flags
    var next_active: map<int, bool> = subscription_active

    next_names[subscription_id] = name
    next_listeners[subscription_id] = listener
    next_once[subscription_id] = once_only
    next_active[subscription_id] = true

    subscription_names = next_names
    subscription_listeners = next_listeners
    subscription_once_flags = next_once
    subscription_active = next_active
    return success()
end

public func route_to_listeners(event_id: int, name: text, payload: text) -> int
    var delivered: int = 0
    var next_event_ids: map<int, int> = delivery_event_ids
    var next_names: map<int, text> = delivery_names
    var next_payloads: map<int, text> = delivery_payloads
    var next_listeners: map<int, text> = delivery_listeners
    var next_pending: map<int, bool> = delivery_pending
    var next_active: map<int, bool> = subscription_active
    var probe: int = 1

    while probe < subscription_next_id
        if events.event_bool_or(subscription_active, probe, false)
            if events.event_text_or(subscription_names, probe, "") == name
                const listener_name: text = events.event_text_or(subscription_listeners, probe, "")
                if listener_name != ""
                    const delivery_id: int = delivery_next_id
                    delivery_next_id = delivery_next_id + 1
                    next_event_ids[delivery_id] = event_id
                    next_names[delivery_id] = name
                    next_payloads[delivery_id] = payload
                    next_listeners[delivery_id] = listener_name
                    next_pending[delivery_id] = true
                    delivered = delivered + 1
                end

                if events.event_bool_or(subscription_once_flags, probe, false)
                    next_active[probe] = false
                end
            end
        end
        probe = probe + 1
    end

    delivery_event_ids = next_event_ids
    delivery_names = next_names
    delivery_payloads = next_payloads
    delivery_listeners = next_listeners
    delivery_pending = next_pending
    subscription_active = next_active
    return delivered
end

public func find_subscription_slot(name: text, listener: text) -> int
    if name == "" or listener == ""
        return 0
    end

    var probe: int = 1
    while probe < subscription_next_id
        if events.event_text_or(subscription_names, probe, "") == name
            if events.event_text_or(subscription_listeners, probe, "") == listener
                return probe
            end
        end
        probe = probe + 1
    end
    return 0
end

public func find_active_subscription_id(name: text, listener: text) -> int
    if name == "" or listener == ""
        return 0
    end

    var probe: int = 1
    while probe < subscription_next_id
        if events.event_bool_or(subscription_active, probe, false)
            if events.event_text_or(subscription_names, probe, "") == name
                if events.event_text_or(subscription_listeners, probe, "") == listener
                    return probe
                end
            end
        end
        probe = probe + 1
    end
    return 0
end

public func event_text_or(values: map<int, text>, id: int, fallback: text) -> text
    const maybe: optional<text> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func event_bool_or(values: map<int, bool>, id: int, fallback: bool) -> bool
    const maybe: optional<bool> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func event_int_by_id_or(values: map<int, int>, id: int, fallback: int) -> int
    const maybe: optional<int> = values.get(id)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func event_int_or(values: map<text, int>, key: text, fallback: int) -> int
    const maybe: optional<int> = values.get(key)
    match maybe
        case value present ->
            return present
        case none ->
            return fallback
    end
end

public func event_text_set(values: map<int, text>, id: int, value: text) -> map<int, text>
    var next: map<int, text> = values
    next[id] = value
    return next
end

public func event_bool_set(values: map<int, bool>, id: int, value: bool) -> map<int, bool>
    var next: map<int, bool> = values
    next[id] = value
    return next
end

public func event_int_set(values: map<text, int>, key: text, value: int) -> map<text, int>
    var next: map<text, int> = values
    next[key] = value
    return next
end
