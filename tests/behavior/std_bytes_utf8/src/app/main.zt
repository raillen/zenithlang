namespace app.main

import std.bytes
import std.text

func main() -> int
    const ok_text: text = "ok"
    const empty_payload: bytes = bytes.empty()
    const utf8_data: bytes = text.to_utf8(ok_text)
    const invalid_utf8: bytes = hex bytes "FF"

    const decoded_ok: result<text, text> = text.from_utf8(utf8_data)
    const decoded_fail: result<text, text> = text.from_utf8(invalid_utf8)

    var score: int = len(empty_payload) + len(utf8_data)

    if decoded_ok != decoded_fail
        score = score + 12
    end

    return score
end