namespace app.main

import std.set as set

func main() -> int
    const left: set<int> = {1, 2, 3}
    const right: set<int> = {3, 4}
    const unioned: set<int> = set.union(left, right)

    if set.len(unioned) != 4
        return 1
    end
    if set.has(unioned, 4) == false
        return 2
    end
    if set.has(unioned, 5)
        return 3
    end

    const intersected: set<int> = set.intersect(left, right)
    if set.len(intersected) != 1
        return 4
    end
    if set.has(intersected, 3) == false
        return 5
    end

    const difference: set<int> = set.difference(left, right)
    if set.len(difference) != 2
        return 6
    end
    if set.has(difference, 3)
        return 7
    end

    const source_words: set<text> = {"zen", "lang"}
    const doc_terms: set<text> = {"lang", "docs"}
    const words: set<text> = set.union(source_words, doc_terms)
    if set.len(words) != 3
        return 8
    end
    if set.has(words, "docs") == false
        return 9
    end
    if set.has(set.difference(source_words, doc_terms), "zen") == false
        return 10
    end

    return 0
end
