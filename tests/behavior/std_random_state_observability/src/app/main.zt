namespace app.main

import std.random as random

func main() -> result<void, text>
    random.seed(7)

    if random.seeded == false
        return error("std.random.seed should set seeded=true")
    end
    if random.last_seed != 7
        return error("std.random.seed should update last_seed")
    end
    if random.draw_count != 0
        return error("std.random.seed should reset draw_count")
    end

    const initial: random.Stats = random.stats()
    if initial.seeded == false or initial.last_seed != 7 or initial.draw_count != 0
        return error("std.random.stats should mirror public state after seed")
    end

    const first: int = random.next()
    const first_copy: int = first
    if first_copy != first
        return error("std.random.next should return a stable draw value")
    end
    if random.draw_count != 1
        return error("std.random.next should increment draw_count by one")
    end

    const ranged: int = random.between(10, 20)?
    if ranged < 10 or ranged > 20
        return error("std.random.between should keep value inside inclusive range")
    end
    if random.draw_count != 2
        return error("std.random.between should increment draw_count by one")
    end

    const current: random.Stats = random.stats()
    if current.seeded == false or current.last_seed != 7 or current.draw_count != 2
        return error("std.random.stats should mirror public state after draws")
    end

    return success()
end
