namespace app.main

import std.fs.path as path

func compile_probe() -> void
    const joined: text = path.join("docs", "guide.md")
    const joined_trailing: text = path.join("docs/", "guide.md")
    const file_name: text = path.base(joined)
    const directory: text = path.dir(joined)
    const extension: text = path.ext(joined)
    const stem: text = path.name_without_extension(joined)
    const has_plain: bool = path.has_ext(joined, "md")
    const has_dot: bool = path.has_ext(joined, ".md")
    const changed: text = path.change_ext(joined, "txt")
    const root_file: text = "/guide.md"
    const root_dir: text = path.dir(root_file)

    const _len_guard: int = len(joined) + len(joined_trailing) + len(file_name) + len(directory) + len(extension) + len(stem) + len(changed) + len(root_dir)
    const _bool_guard: bool = has_plain or has_dot
    return
end

func main() -> result<void, text>
    return success()
end
