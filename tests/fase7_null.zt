-- Regression Test: Stage 7 (Null Elimination)
-- Objective: Validate that direct literal null now raises semantic error ZT-S106.

func main()
    -- 1. Literal null in nullable context must fail with ZT-S106
    var x: int? = null

    -- 2. Assignment to non-nullable still also triggers type error ZT-S100
    var y: int = null

    -- 3. Idiomatic absence should use Empty/Optional/Outcome instead of null
    print("Stage 7: direct null should be rejected")
end
