-- tests/core/test_spread.zt
-- Teste do Operador Spread (..) em Expressões

pub func main() -> int
    print("--- Teste Spread Operator ---")
    
    -- 1. Spread em Listas
    var base: any = [1, 2]
    var combo: any = [0, ..base, 3, 4]
    
    print("Combo Lista: " + combo)
    check #combo == 5 else error("Tamanho da lista combo errado") end
    check combo[1] == 0 and combo[3] == 2 else error("Valores da lista combo errados") end
    
    -- 2. Spread em Mapas
    var config: any = { "tema": "escuro", "fonte": 12 }
    var usuario: any = { ..config, "usuario": "Rafael", "fonte": 14 }
    
    print("Config Usuário: " + usuario)
    -- 'fonte' deve ter sido sobrescrito por 14
    check usuario["tema"] == "escuro" else error("Campo 'tema' perdido") end
    check usuario["fonte"] == 14 else error("Campo 'fonte' não sobrescrito") end
    
    print("Spread Operator Tests Passed!")
    return 0
end
