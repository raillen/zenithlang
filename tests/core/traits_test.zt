trait Descrevivel
    func descrever() -> text
end

struct Pessoa
    nome: text
    idade: int
end

apply Descrevivel to Pessoa
    func descrever() -> text
        return @nome + ", " + @idade + " anos"
    end
end

func imprimir_descricao(d: Descrevivel) -> text
    return d.descrever()
end

func main() -> int
    var alice: Pessoa = Pessoa { nome: "Alice", idade: 30 }
    if alice.descrever() != "Alice, 30 anos"
        return 1
    end

    var bob: Pessoa = Pessoa { nome: "Bob", idade: 25 }
    if imprimir_descricao(bob) != "Bob, 25 anos"
        return 1
    end

    return 0
end
