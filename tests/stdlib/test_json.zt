import std.json

pub func main() -> int
    print("--- Testando Módulo std.json ---")

    var raw_json = "\{ \"nome\": \"Zenith\", \"versao\": 0.2 \}"
    
    -- 1. Testando Parse
    print("Testando parse genérico...")
    var res_parse = json.parse(raw_json)
    match res_parse
        case Success(obj) =>
            var mapa: any = obj
            print("Nome: " + mapa.nome)
        case Failure(e) =>
            print("Erro no parse")
    end

    -- 2. Testando Stringify
    print("\nTestando stringify:")
    var data = { "id": 1, "autor": "Rafael" }
    var s = json.stringify(data, 0)
    print(s)

    -- 3. Testando Beautify
    print("\nTestando beautify:")
    var res_b = json.beautify(s, 2)
    match res_b
        case Success(b) =>
            print(b)
        case Failure(e) =>
            print("Erro no beautify")
    end

    print("\n--- Fim dos testes ---")
    return 0
end
