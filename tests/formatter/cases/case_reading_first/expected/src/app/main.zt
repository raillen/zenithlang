namespace app.main

import std.validate as validate

trait TextRenderable<Item>
    func render(value: Item) -> text
end

-- comment should stay above long signature
func render_report<Item, Error>(
    title: text where validate.not_empty(title),
    subtitle: text where validate.not_empty(subtitle),
    items: list<Item>,
    render: func(Item) -> text
) -> text
where Item is TextRenderable<Item> and Error is TextRenderable<Error>
    const header: text = title
    match header
        case title ->
            -- render comment stays with return
            return render(items[0])
        case default ->
            return subtitle
    end
end

func main() -> int 
    return 0
end
