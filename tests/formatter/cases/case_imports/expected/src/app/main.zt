namespace app.main

import std.text as text
-- keep validation explicit
import std.validate as validate
import std.io as io

func main() -> int 
    const raw: text = "  hi  "
    const cleaned: text = text.trim(raw)
    if validate.not_empty(cleaned) 
        io.write(cleaned)
        io.write("\n")
        return 0
    end
    return 1
end
