namespace app.main

enum Shape
    Circle(radius: int)
    Rectangle(width: int, height: int)
    Point
end

func area(shape: Shape) -> int 
    match shape
        case Shape.Circle(r) ->
            return r * r
        case Shape.Rectangle(w, h) ->
            return w * h
        case Shape.Point ->
            return 0
    end
end

func main() -> int 
    const value: Shape = Shape.Rectangle(width: 5, height: 4)
    return area(value)
end
