namespace app.main

import std.validate as validate
import std.io as io

-- formatter golden input
struct User
    name: text where validate.not_empty(it)
    age: int where it >= 0
end

enum Result
    Ok
    Err(message: text)
end

func calc(value: int where value > 0, label: text) -> int 
    const r: Result = Result.Ok
    match r
        case Result.Ok:
            return pick(1, bonus: 2, extra: 3)
        case Result.Err(message):
            return 0
    end
end

func pick(base: int, bonus: int, extra: int) -> int 
    return base + bonus + extra
end

func main() -> int 
    const u: User = User(name: "Ana", age: 20)
    if calc(1, label: u.name) > 0 
        io.write("ok")
        io.write("\n")
        return 0
    end
    return 1
end
