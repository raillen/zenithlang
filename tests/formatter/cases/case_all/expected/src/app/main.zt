namespace app.main

import std.validate as validate
-- formatter golden input
import std.io as io

struct User
    name: text where name -> validate.not_empty(it)
    age: int where age -> it >= 0
end

enum Result
    Ok,
    Err(message: text)
end

func calc(value: int where value -> value > 0, label: text) -> int 
    const r: Result = Result.Ok
    match r
        case Result.Ok -> 
            return pick(1, bonus: 2, extra: 3)
        end
        case Result.Err(message) -> 
            return 0
        end
    end
end

func pick(base: int, bonus: int, extra: int) -> int 
    return base + bonus + extra
end

func main() -> int 
    const u: User = User(name: Ana, age: 20)
    if calc(1, label: u.name) > 0 
        io.print_line(ok)
        return 0
    end
    return 1
end
