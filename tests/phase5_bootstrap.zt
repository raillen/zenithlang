func test_gate() -> int
    var list: list<int> = [1, 2, 3]
    var status_by_name: map<text, int> = { "status": 200 }
    var ok: bool = not (1 == 2) and (list[1] == 1)
    
    if ok
        return status_by_name["status"]
    end
    return 0
end

var final_status: int = test_gate()
print(final_status)
