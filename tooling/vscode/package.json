{
  "name": "zenith",
  "displayName": "Zenith Language",
  "description": "Zenith Next language support for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:zenith"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zenith",
        "aliases": [
          "Zenith",
          "zenith"
        ],
        "extensions": [
          ".zt",
          ".zdoc",
          ".ztproj"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zenith",
        "scopeName": "source.zenith",
        "path": "./syntaxes/zenith.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zenith",
        "path": "./snippets/zenith.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
