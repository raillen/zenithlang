{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zenith",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zenith",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zenith",
          "match": "\\b(if|else|while|for|repeat|match|case|break|continue|return|in|times|default)\\b"
        },
        {
          "name": "keyword.other.zenith",
          "match": "\\b(func|struct|trait|apply|enum|extern|const|var|public|namespace|import|as|where|is|to)\\b"
        },
        {
          "name": "support.type.zenith",
          "match": "\\b(int|float|bool|text|bytes|void|list|map|optional|result|success|error|none)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zenith",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.zenith",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.triple.zenith",
          "begin": "\"\"\"",
          "end": "\"\"\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.zenith",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    }
  },
  "scopeName": "source.zenith"
}
